# Environment Variables Example
# Copy this file to .env and fill in your actual values

# Site Configuration
# SITE_URL=https://finan.eu.com
# SITE_NAME=FiNAN

# Analytics (if needed in the future)
# GOOGLE_ANALYTICS_ID=
# GOOGLE_TAG_MANAGER_ID=

# Email Configuration (if contact forms are added)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# API Keys (if external services are integrated)
# API_KEY_EXAMPLE=

# Security
# SESSION_SECRET=
# CSRF_SECRET=