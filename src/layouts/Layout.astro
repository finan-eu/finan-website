---
import '../styles/global.css';
import { SEO } from 'astro-seo';
import { ClientRouter } from 'astro:transitions';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import StructuredData from '../components/StructuredData.astro';
import { seoConfig, getFullUrl, getPageTitle } from '../data/siteConfig';

// Domain detection for automatic noindex on pages.dev
const PAGES_DEV_PATTERN = /\.pages\.dev$/i;
const hostname = Astro.url.hostname;
const isPagesDevDomain = PAGES_DEV_PATTERN.test(hostname);

// Force noindex/nofollow on pages.dev domains
const forceNoIndex = isPagesDevDomain;
const forceNoFollow = isPagesDevDomain;

// Props interface for page-level SEO overrides
interface Props {
  /** Page title (will be formatted with titleTemplate) */
  title?: string;
  /** Page description */
  description?: string;
  /** Social sharing image path or URL */
  image?: string;
  /** Whether this is an article page */
  article?: boolean;
  /** Article published time (ISO 8601) */
  publishedTime?: string;
  /** Article modified time (ISO 8601) */
  modifiedTime?: string;
  /** Prevent search engine indexing */
  noindex?: boolean;
  /** Prevent search engines from following links */
  nofollow?: boolean;
  /** Additional keywords to append */
  keywords?: string[];
  /** Enable motion scroll animations bundle on this page */
  enableMotion?: boolean;
  /** Render the shared site navbar */
  showNavbar?: boolean;
  /** Render the shared site footer */
  showFooter?: boolean;
  /** Additional classes for the main landmark */
  mainClass?: string;
}

const {
  title,
  description,
  image = seoConfig.openGraph.image,
  article = false,
  publishedTime,
  modifiedTime,
  noindex = forceNoIndex,
  nofollow = forceNoFollow,
  keywords,
  enableMotion = false,
  showNavbar = true,
  showFooter = true,
  mainClass,
} = Astro.props;

// Process title with template if provided
const pageTitle = title ? getPageTitle(title) : seoConfig.basic.title;
const normalizedTitle = title?.replace(/\s*-\s*FiNAN$/i, '').trim();
const pageDescription =
  description ??
  (normalizedTitle
    ? `${normalizedTitle} updates, programs, and guidance from FiNAN for Filipino nurses in the Nordic region.`
    : seoConfig.basic.description);

// Construct full image URL
const fullImageUrl = getFullUrl(image);

// Merge keywords
const allKeywords = keywords
  ? [...seoConfig.meta.keywords, ...keywords]
  : seoConfig.meta.keywords;

// Construct robots meta value
const robotsValue =
  noindex || nofollow
    ? `${noindex ? 'noindex' : 'index'}, ${nofollow ? 'nofollow' : 'follow'}`
    : seoConfig.meta.robots;
---

<!doctype html>
<html lang={seoConfig.basic.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="format-detection" content="telephone=no" />
    <ClientRouter />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="application-name" content="FiNAN" />
    <meta name="apple-mobile-web-app-title" content="FiNAN" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="generator" content={Astro.generator} />
    <meta
      http-equiv="Cache-Control"
      content="public, max-age=31536000, immutable"
    />

    <!-- Self-hosted Open Sans font preloads -->
    <link
      rel="preload"
      href="/fonts/OpenSans-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/OpenSans-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- SEO Component -->
    <SEO
      title={pageTitle}
      description={pageDescription}
      canonical={seoConfig.additional.enableCanonical
        ? Astro.url.href
        : undefined}
      noindex={noindex}
      nofollow={nofollow}
      openGraph={{
        basic: {
          title: pageTitle,
          type: article ? 'article' : seoConfig.openGraph.type,
          image: fullImageUrl,
          url: Astro.url.href,
        },
        optional: {
          description: pageDescription,
          siteName: seoConfig.openGraph.siteName,
          locale: seoConfig.openGraph.locale,
        },
        image: {
          width: seoConfig.openGraph.imageWidth,
          height: seoConfig.openGraph.imageHeight,
          alt: seoConfig.openGraph.imageAlt,
        },
        ...(article &&
          publishedTime &&
          modifiedTime && {
            article: {
              publishedTime: publishedTime,
              modifiedTime: modifiedTime,
            },
          }),
      }}
      twitter={{
        card: seoConfig.twitter.cardType,
        site: seoConfig.twitter.site ? `@${seoConfig.twitter.site}` : undefined,
        creator: seoConfig.twitter.creator
          ? `@${seoConfig.twitter.creator}`
          : undefined,
        title: pageTitle,
        description: pageDescription,
        image: fullImageUrl,
        imageAlt: seoConfig.twitter.imageAlt,
      }}
      extend={{
        meta: [
          { name: 'author', content: seoConfig.basic.author },
          { name: 'keywords', content: allKeywords.join(', ') },
          { name: 'robots', content: robotsValue },
          ...(seoConfig.meta.themeColor
            ? [{ name: 'theme-color', content: seoConfig.meta.themeColor }]
            : []),
          ...(seoConfig.meta.mobileWebAppCapable
            ? [{ name: 'mobile-web-app-capable', content: 'yes' }]
            : []),
          ...(seoConfig.meta.appleMobileWebAppStatusBarStyle
            ? [
                {
                  name: 'apple-mobile-web-app-status-bar-style',
                  content: seoConfig.meta.appleMobileWebAppStatusBarStyle,
                },
              ]
            : []),
        ],
      }}
    />

    <!-- Structured Data -->
    <!--
      Only include WebSite schema on the homepage to help Google identify the correct Site Name.
      Organization schema is included on all pages to establish ownership.
    -->
    <StructuredData
      schemas={Astro.url.pathname === '/'
        ? ['organization', 'website']
        : ['organization']}
    />

    <!-- Additional head content from pages -->
    <slot name="head" />
  </head>
  <body>
    <div id="page-content">
      {showNavbar && <Navbar />}
      <main class={mainClass}>
        <slot />
      </main>
      {showFooter && <Footer />}
    </div>

    <!-- Mobile Viewport Height Fix Script -->
    <!-- <script>
      // Set the custom property to the actual viewport height
      function setVH() {
        let vh = window.innerHeight * 0.01;
        document.documentElement.style.setProperty('--vh', `${vh}px`);
      }

      // Set on load
      setVH();

      // Update on resize and orientation change with debouncing
      let resizeTimer = 0;
      function debouncedSetVH() {
        clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(setVH, 100);
      }

      window.addEventListener('resize', debouncedSetVH);
      window.addEventListener('orientationchange', function () {
        // Wait a bit for orientation change to complete
        window.setTimeout(setVH, 100);
      });

      // Also set on page show (for back/forward navigation)
      window.addEventListener('pageshow', setVH);
    </script> -->
    <!-- Motion Scroll Animations -->
    {enableMotion && <script src="../lib/init-motion-animations.ts" />}
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
