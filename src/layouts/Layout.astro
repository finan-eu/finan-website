---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { cspString } from '../../security.config.js';
import { SEO } from 'astro-seo';
import { seoConfig, getFullUrl, getPageTitle } from '../data/siteConfig';

// Domain detection for automatic noindex on pages.dev
const PAGES_DEV_PATTERN = /\.pages\.dev$/i;
const hostname = Astro.url.hostname;
const isPagesDevDomain = PAGES_DEV_PATTERN.test(hostname);

// Force noindex/nofollow on pages.dev domains
const forceNoIndex = isPagesDevDomain;
const forceNoFollow = isPagesDevDomain;

// Props interface for page-level SEO overrides
interface Props {
  /** Page title (will be formatted with titleTemplate) */
  title?: string;
  /** Page description */
  description?: string;
  /** Social sharing image path or URL */
  image?: string;
  /** Whether this is an article page */
  article?: boolean;
  /** Article published time (ISO 8601) */
  publishedTime?: string;
  /** Article modified time (ISO 8601) */
  modifiedTime?: string;
  /** Prevent search engine indexing */
  noindex?: boolean;
  /** Prevent search engines from following links */
  nofollow?: boolean;
  /** Additional keywords to append */
  keywords?: string[];
}

const {
  title,
  description = seoConfig.basic.description,
  image = seoConfig.openGraph.image,
  article = false,
  publishedTime,
  modifiedTime,
  noindex = forceNoIndex,
  nofollow = forceNoFollow,
  keywords,
} = Astro.props;

// Process title with template if provided
const pageTitle = title ? getPageTitle(title) : seoConfig.basic.title;

// Construct full image URL
const fullImageUrl = getFullUrl(image);

// Merge keywords
const allKeywords = keywords
  ? [...seoConfig.meta.keywords, ...keywords]
  : seoConfig.meta.keywords;

// Construct robots meta value
const robotsValue =
  noindex || nofollow
    ? `${noindex ? 'noindex' : 'index'}, ${nofollow ? 'nofollow' : 'follow'}`
    : seoConfig.meta.robots;
---

<!doctype html>
<html lang={seoConfig.basic.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="format-detection" content="telephone=no" />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="FiNAN" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="generator" content={Astro.generator} />
    <meta
      http-equiv="Cache-Control"
      content="public, max-age=31536000, immutable"
    />

    <!-- Google Fonts Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts - Optimized Loading -->
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700;800&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript
      ><link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700;800&display=swap"
      /></noscript
    >

    <!-- Security Headers -->
    <meta http-equiv="Content-Security-Policy" content={cspString} />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta
      http-equiv="Referrer-Policy"
      content="strict-origin-when-cross-origin"
    />

    <!-- SEO Component -->
    <SEO
      title={pageTitle}
      description={description}
      canonical={seoConfig.additional.enableCanonical
        ? Astro.url.href
        : undefined}
      noindex={noindex}
      nofollow={nofollow}
      openGraph={{
        basic: {
          title: pageTitle,
          type: article ? 'article' : seoConfig.openGraph.type,
          image: fullImageUrl,
          url: Astro.url.href,
        },
        optional: {
          description: description,
          siteName: seoConfig.openGraph.siteName,
          locale: seoConfig.openGraph.locale,
        },
        image: {
          width: seoConfig.openGraph.imageWidth,
          height: seoConfig.openGraph.imageHeight,
          alt: seoConfig.openGraph.imageAlt,
        },
        ...(article &&
          publishedTime &&
          modifiedTime && {
            article: {
              publishedTime: publishedTime,
              modifiedTime: modifiedTime,
            },
          }),
      }}
      twitter={{
        card: seoConfig.twitter.cardType,
        site: seoConfig.twitter.site ? `@${seoConfig.twitter.site}` : undefined,
        creator: seoConfig.twitter.creator
          ? `@${seoConfig.twitter.creator}`
          : undefined,
        title: pageTitle,
        description: description,
        image: fullImageUrl,
        imageAlt: seoConfig.twitter.imageAlt,
      }}
      extend={{
        meta: [
          { name: 'author', content: seoConfig.basic.author },
          { name: 'keywords', content: allKeywords.join(', ') },
          { name: 'robots', content: robotsValue },
          ...(seoConfig.meta.themeColor
            ? [{ name: 'theme-color', content: seoConfig.meta.themeColor }]
            : []),
          ...(seoConfig.meta.mobileWebAppCapable
            ? [{ name: 'mobile-web-app-capable', content: 'yes' }]
            : []),
          ...(seoConfig.meta.appleMobileWebAppStatusBarStyle
            ? [
                {
                  name: 'apple-mobile-web-app-status-bar-style',
                  content: seoConfig.meta.appleMobileWebAppStatusBarStyle,
                },
              ]
            : []),
        ],
      }}
    />

    <!-- View Transitions -->
    <ClientRouter />

    <!-- Additional head content from pages -->
    <slot name="head" />
  </head>
  <body>
    <div id="page-content" transition:animate="fade">
      <slot />
    </div>

    <!-- Mobile Viewport Height Fix Script -->
    <!-- <script>
      // Set the custom property to the actual viewport height
      function setVH() {
        let vh = window.innerHeight * 0.01;
        document.documentElement.style.setProperty('--vh', `${vh}px`);
      }

      // Set on load
      setVH();

      // Update on resize and orientation change with debouncing
      let resizeTimer = 0;
      function debouncedSetVH() {
        clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(setVH, 100);
      }

      window.addEventListener('resize', debouncedSetVH);
      window.addEventListener('orientationchange', function () {
        // Wait a bit for orientation change to complete
        window.setTimeout(setVH, 100);
      });

      // Also set on page show (for back/forward navigation)
      window.addEventListener('pageshow', setVH);
    </script> -->
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
