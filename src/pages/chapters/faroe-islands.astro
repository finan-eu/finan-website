---
import Layout from '../../layouts/Layout.astro';
import TopBanner from '../../components/TopBanner.astro';
import Navbar from '../../components/Navbar.astro';
import PageHeader from '../../components/PageHeader.astro';
import CTABanner from '../../components/CTABanner.astro';
import Footer from '../../components/Footer.astro';
import heroImage from '../../assets/images/chapters/faroe-islands/faroe-islands-banner.webp';
import WorkingCommittee from '../../components/WorkingCommittee.astro';
---

<Layout title="Faroe Islands - FiNAN">
  <main>
    <TopBanner />
    <Navbar />
    <PageHeader
      title="Faroe Islands"
      description="Explore unique healthcare opportunities in the Faroe Islands, a remote Nordic archipelago with close-knit communities and pristine natural beauty."
      backgroundImage={heroImage}
      backgroundAlt="Tórshavn, Faroe Islands"
    />

    <section class="bg-white py-16">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-6">
        <header class="max-w-2xl">
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 md:text-4xl">
            Healthcare in the Faroe Islands
          </h2>
        </header>

        <div class="mt-4">
          <p class="mb-6 text-lg text-gray-700">
            The Faroe Islands offer a unique opportunity for Filipino healthcare
            professionals to work in a small, tight-knit community where every
            contribution makes a significant impact. Located between Iceland and
            Norway, this autonomous territory within Denmark provides a
            distinctive Nordic healthcare experience.
          </p>

          <p class="mb-6 text-lg text-gray-700">
            With a population of approximately 53,000 people spread across 18
            islands, the Faroese healthcare system emphasizes community care,
            preventive medicine, and close patient-provider relationships.
            Healthcare professionals here enjoy the chance to work across
            various specialties and develop strong connections with the local
            community.
          </p>

          <h3 class="mb-4 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl">
            Healthcare System
          </h3>
          <p class="mb-6 text-lg text-gray-700">
            The Faroese healthcare system operates under Danish healthcare
            principles but is adapted to the unique geographic and demographic
            challenges of island life. The National Hospital in Tórshavn serves
            as the main medical facility, with smaller health centers
            distributed across the islands, often requiring healthcare
            professionals to be versatile and adaptable.
          </p>

          <h3 class="mb-4 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl">
            Island Life and Culture
          </h3>
          <p class="mb-6 text-lg text-gray-700">
            Living in the Faroe Islands means embracing a slower pace of life
            surrounded by dramatic landscapes, including grass-roof houses,
            steep cliffs, and pristine fjords. The Faroese culture values
            community, tradition, and environmental stewardship, creating a
            welcoming atmosphere for international healthcare professionals
            seeking a unique Nordic experience.
          </p>

          <h3 class="mb-4 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl">
            Professional Opportunities
          </h3>
          <p class="text-lg text-gray-700">
            Healthcare professionals in the Faroe Islands often work across
            multiple specialties and have opportunities for diverse clinical
            experiences. The small population means that professionals can make
            a real difference in community health outcomes while enjoying
            excellent work-life balance and the opportunity to explore one of
            the world's most beautiful archipelagos.
          </p>
        </div>
      </div>
    </section>
    <WorkingCommittee country="faroe-islands" />
    <CTABanner />
  </main>
  <Footer />
</Layout>
