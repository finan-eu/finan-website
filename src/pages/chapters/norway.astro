---
import Layout from '../../layouts/Layout.astro';
import TopBanner from '../../components/TopBanner.astro';
import Navbar from '../../components/Navbar.astro';
import PageHeader from '../../components/PageHeader.astro';
import CTABanner from '../../components/CTABanner.astro';
import Footer from '../../components/Footer.astro';
import heroImage from '../../assets/images/chapters/norway/norway-banner.webp';
import WorkingCommittee from '../../components/WorkingCommittee.astro';
---

<Layout title="Norway - FiNAN">
  <main>
    <TopBanner />
    <Navbar />
    <PageHeader
      title="Norway"
      description="Discover healthcare opportunities in Norway, renowned for its comprehensive welfare system, natural beauty, and commitment to healthcare excellence."
      backgroundImage={heroImage}
      backgroundAlt="Oslo, Norway"
    />

    <section class="bg-white py-16">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-6">
        <header class="max-w-2xl">
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 md:text-4xl">
            Healthcare in Norway
          </h2>
        </header>

        <div class="mt-4">
          <p class="mb-6 text-lg text-gray-700">
            Norway offers exceptional opportunities for Filipino healthcare
            professionals in a country renowned for its comprehensive welfare
            system, high quality of life, and stunning natural beauty. The
            Norwegian healthcare system is publicly funded and emphasizes
            universal access to high-quality care for all residents.
          </p>

          <p class="mb-6 text-lg text-gray-700">
            Healthcare professionals in Norway benefit from excellent working
            conditions, competitive salaries, and comprehensive social benefits.
            The country's commitment to work-life balance, professional
            development, and evidence-based medicine creates an ideal
            environment for career growth and personal fulfillment.
          </p>

          <h3 class="mb-4 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl">
            World-Class Healthcare System
          </h3>
          <p class="mb-6 text-lg text-gray-700">
            Norway's healthcare system is organized into four regional health
            authorities, providing comprehensive services from primary care to
            highly specialized treatments. The system emphasizes prevention,
            patient safety, and quality improvement, offering healthcare
            professionals opportunities to work with advanced medical technology
            and participate in international research collaborations.
          </p>

          <h3 class="mb-4 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl">
            Natural Beauty and Culture
          </h3>
          <p class="mb-6 text-lg text-gray-700">
            Living in Norway means access to spectacular fjords, mountains, and
            the midnight sun. Norwegian culture values equality, environmental
            stewardship, and outdoor activities, creating a welcoming community
            for international professionals. The concept of "friluftsliv"
            (outdoor life) is central to Norwegian culture, promoting work-life
            balance and connection with nature.
          </p>

          <h3 class="mb-4 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl">
            Professional Growth
          </h3>
          <p class="text-lg text-gray-700">
            Norwegian healthcare emphasizes continuous learning and professional
            development. Healthcare professionals have access to excellent
            training programs, research opportunities, and international
            exchanges. The country's investment in healthcare innovation and
            technology provides exciting opportunities for career advancement
            and contribution to global health improvements.
          </p>
        </div>
      </div>
    </section>
    <WorkingCommittee country="norway" />
    <CTABanner />
  </main>
  <Footer />
</Layout>
