---
import Layout from '../../layouts/Layout.astro';
import TopBanner from '../../components/TopBanner.astro';
import Navbar from '../../components/Navbar.astro';
import PageHeader from '../../components/PageHeader.astro';
import CTABanner from '../../components/CTABanner.astro';
import Footer from '../../components/Footer.astro';
import heroImage from '../../assets/images/chapters/finland/finland-banner.webp';
import WorkingCommittee from '../../components/WorkingCommittee.astro';
---

<Layout title="Finland - FiNAN">
  <main>
    <TopBanner />
    <Navbar />
    <PageHeader
      title="Finland"
      description="Discover healthcare opportunities in Finland, the land of a thousand lakes, known for innovation, education excellence, and comprehensive healthcare."
      backgroundImage={heroImage}
      backgroundAlt="Helsinki, Finland"
    />

    <section class="bg-white py-16">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-6">
        <header class="max-w-2xl">
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 md:text-4xl">
            Healthcare in Finland
          </h2>
        </header>

        <div class="mt-4">
          <p class="mb-6 text-lg text-gray-700">
            Finland offers exceptional opportunities for Filipino healthcare
            professionals in a country renowned for its world-class education
            system, technological innovation, and comprehensive healthcare
            coverage. Known as the "Land of a Thousand Lakes," Finland combines
            cutting-edge medical technology with a strong commitment to patient
            care and professional development.
          </p>

          <p class="mb-6 text-lg text-gray-700">
            The Finnish healthcare system is built on the principles of
            equality, accessibility, and quality care for all residents.
            Healthcare professionals benefit from excellent working conditions,
            competitive compensation, and extensive opportunities for continuing
            education and specialization.
          </p>

          <h3 class="mb-4 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl">
            Healthcare System Excellence
          </h3>
          <p class="mb-6 text-lg text-gray-700">
            Finland's healthcare system combines public and private sectors
            effectively, with municipalities responsible for organizing
            healthcare services. The country is known for its innovative digital
            health solutions, research excellence, and emphasis on preventive
            care, providing healthcare professionals with opportunities to work
            with the latest medical technologies and evidence-based practices.
          </p>

          <h3 class="mb-4 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl">
            Finnish Culture and Lifestyle
          </h3>
          <p class="mb-6 text-lg text-gray-700">
            Finland offers a unique Nordic lifestyle characterized by a close
            connection to nature, seasonal celebrations, and the concept of
            "sisu" - determination and resilience. The country provides
            excellent work-life balance, with extensive parental leave policies,
            outdoor recreation opportunities, and a strong social support system
            that values international professionals.
          </p>

          <h3 class="mb-4 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl">
            Professional Development
          </h3>
          <p class="text-lg text-gray-700">
            Finnish healthcare emphasizes continuous learning and professional
            growth. Healthcare professionals have access to world-class training
            programs, research opportunities, and international collaboration.
            The country's commitment to innovation in healthcare technology
            provides exciting opportunities for career advancement and
            specialization.
          </p>
        </div>
      </div>
    </section>
    <WorkingCommittee country="finland" />
    <CTABanner />
  </main>
  <Footer />
</Layout>
