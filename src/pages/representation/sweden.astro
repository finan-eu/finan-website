---
import Layout from '../../layouts/Layout.astro';
import TopBanner from '../../components/TopBanner.astro';
import Navbar from '../../components/Navbar.astro';
import PageHeader from '../../components/PageHeader.astro';
import CTABanner from '../../components/CTABanner.astro';
import Footer from '../../components/Footer.astro';
import heroImage from '../../assets/images/representation/sweden/sweden-banner.webp';
import WorkingCommittee from '../../components/WorkingCommittee.astro';
import BlogRepresentation from '../../components/BlogRepresentation.astro';
---

<Layout title="Sweden - FiNAN">
  <main>
    <TopBanner />
    <Navbar />
    <PageHeader
      title="Sweden"
      description="Welcome to the Regional Representation Site of the Filipino Nurses Association in the Nordic Region – Sweden (FiNAN Sweden)"
      contactEmail="sweden@finan.eu.com"
      backgroundImage={heroImage}
      backgroundAlt="Stockholm, Sweden"
    />

    <section class="bg-white py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <!-- FiNAN Sweden -->
        <h2
          class="pb-4 text-3xl font-bold tracking-tight text-gray-900 md:text-4xl"
        >
          Welcome! Välkommen! Mabuhay!
        </h2>

        <p class="mb-10 text-lg text-gray-700">
          The Sweden Chapter was established in 2020 to address the unique needs
          and challenges of Filipino nurses living and working in Sweden. Since
          private employers began recruiting Filipino nurses in 2010, the
          presence of a dedicated non-profit organization has become essential.
          Our regional representation advocates for fair recruitment, ethical
          integration, and improved working conditions for Filipino nurses
          within Sweden’s health and social care systems.
        </p>

        <!-- Our Commitment -->
        <h2
          class="pb-4 text-3xl font-bold tracking-tight text-gray-900 md:text-4xl"
        >
          Why We Exist
        </h2>
        <p class="mb-6 text-lg text-gray-700">
          Filipino nurses play a vital role in Swedish healthcare, contributing
          to patient safety, culturally competent care, and workforce
          sustainability. However, migration brings challenges such as
          deskilling, language barriers, and adaptation to new clinical
          environments. Our working committee works to:
        </p>

        <ul class="list-disc space-y-2 pl-6 text-lg text-gray-700">
          <li>Promote professional development and continuing education.</li>
          <li>Support cultural integration and mental well-being.</li>
          <li>
            Engage in policy dialogue to ensure compliance with WHO's Global
            Code of Practice on International Recruitment of Health Personnel.
          </li>
          <li>
            Share evidence-based practices and research through our official
            publication, Nordic Puls.
          </li>
        </ul>

        <p class="mt-6 text-lg text-gray-700">
          Our initiatives are grounded in research and global health frameworks,
          aligning with Sustainable Development Goals and ethical recruitment
          standards. We collaborate with healthc are institutions, educational
          bodies, and policymakers to strengthen the role of internationally
          educated nurses in Sweden.
        </p>
      </div>
    </section>
    <WorkingCommittee
      country="sweden"
      heading="Working Committee"
      description="Our leadership team consists of experienced nurses committed to empowering Filipino professionals in Sweden:"
    />

    <section id="our-commitment">
      <div class="mx-auto max-w-4xl px-4 pb-16 sm:px-6">
        <!-- Our Commitment -->
        <h2
          class="pb-4 text-3xl font-bold tracking-tight text-gray-900 md:text-4xl"
        >
          Our Commitment
        </h2>
        <p class="mb-10 text-lg text-gray-700">
          We strive to ensure that Filipino nurses in Sweden are not only
          integrated but thrive professionally and personally. Through advocacy,
          education, and community engagement, we aim to create a supportive
          environment where every nurse feels valued and respected.
          <br />
          <br />
          For inquiries, collaborations, or membership, contact us at: <strong
            >sweden@finan.eu.com</strong
          >
        </p>
      </div>
    </section>

    <BlogRepresentation country="sweden" />

    <CTABanner />
  </main>
  <Footer />
</Layout>
