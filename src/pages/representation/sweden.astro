---
import Layout from '../../layouts/Layout.astro';
import TopBanner from '../../components/TopBanner.astro';
import Navbar from '../../components/Navbar.astro';
import PageHeader from '../../components/PageHeader.astro';
import CTABanner from '../../components/CTABanner.astro';
import Footer from '../../components/Footer.astro';
import heroImage from '../../assets/images/representation/sweden/sweden-banner.webp';
import WorkingCommittee from '../../components/WorkingCommittee.astro';
---

<Layout title="Sweden - FiNAN">
  <main>
    <TopBanner />
    <Navbar />
    <PageHeader
      title="Sweden"
      description="Explore healthcare opportunities in Sweden, known for innovation, equality, and a progressive healthcare system that values international professionals."
      backgroundImage={heroImage}
      backgroundAlt="Stockholm, Sweden"
    />

    <section class="bg-white py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <header class="max-w-2xl">
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 md:text-4xl">
            Healthcare in Sweden
          </h2>
        </header>

        <div class="mt-4">
          <p class="mb-6 text-lg text-gray-700">
            Sweden provides outstanding opportunities for Filipino healthcare
            professionals in a country renowned for its innovation, equality,
            and progressive healthcare system. Known for its commitment to
            universal healthcare, Sweden offers a supportive environment where
            international professionals can thrive while contributing to
            world-class patient care.
          </p>

          <p class="mb-6 text-lg text-gray-700">
            The Swedish healthcare system emphasizes evidence-based medicine,
            patient-centered care, and continuous improvement. Healthcare
            professionals benefit from excellent working conditions,
            comprehensive benefits, and a culture that values work-life balance
            and professional development.
          </p>

          <h3 class="mb-4 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl">
            Progressive Healthcare System
          </h3>
          <p class="mb-6 text-lg text-gray-700">
            Sweden's healthcare system is decentralized across 21 regions, each
            responsible for healthcare delivery in their area. The system is
            known for its emphasis on primary care, preventive medicine, and
            integration of digital health technologies. Healthcare professionals
            have opportunities to work in diverse settings, from cutting-edge
            research hospitals to community health centers.
          </p>

          <h3 class="mb-4 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl">
            Swedish Culture and Lifestyle
          </h3>
          <p class="mb-6 text-lg text-gray-700">
            Living in Sweden means embracing the concepts of "lagom" (balance)
            and "allemansrätten" (right to roam), reflecting Swedish values of
            moderation and connection with nature. The country offers beautiful
            archipelagos, forests, and cities that blend historical charm with
            modern innovation. Swedish culture values equality, sustainability,
            and inclusivity, creating a welcoming environment for international
            healthcare professionals.
          </p>

          <h3 class="mb-4 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl">
            Innovation and Development
          </h3>
          <p class="text-lg text-gray-700">
            Sweden is a global leader in healthcare innovation, digital health
            solutions, and medical research. Healthcare professionals have
            access to cutting-edge technology, research opportunities, and
            international collaborations. The country's investment in healthcare
            education and professional development ensures that healthcare
            workers can continuously advance their skills and contribute to
            improving global health outcomes.
          </p>
        </div>
      </div>
    </section>
    <WorkingCommittee country="sweden" />
    <CTABanner />
  </main>
  <Footer />
</Layout>
