---
import Layout from '../../layouts/Layout.astro';
import TopBanner from '../../components/TopBanner.astro';
import Navbar from '../../components/Navbar.astro';
import PageHeader from '../../components/PageHeader.astro';
import CTABanner from '../../components/CTABanner.astro';
import Footer from '../../components/Footer.astro';
import heroImage from '../../assets/images/representation/denmark/denmark-banner.webp';
import Committee from '../../components/Committee.astro';
import BlogRepresentation from '../../components/BlogRepresentation.astro';
---

<Layout title="Denmark - FiNAN">
  <main>
    <TopBanner />
    <Navbar />
    <PageHeader
      title="Denmark"
      description="Discover opportunities for Filipino healthcare professionals in Denmark, known for its high quality of life and progressive healthcare system."
      backgroundImage={heroImage}
      backgroundAlt="Copenhagen, Denmark"
    />

    <section class="bg-white py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <header class="max-w-2xl">
          <h2
            class="text-3xl font-bold tracking-tight text-gray-900 md:text-4xl"
          >
            Working in Denmark
          </h2>
        </header>

        <div class="mt-4">
          <p class="mb-6 text-lg text-gray-700">
            Denmark offers exceptional opportunities for Filipino healthcare
            professionals seeking to advance their careers in a progressive
            Nordic healthcare system. Known for its work-life balance,
            comprehensive social benefits, and commitment to quality patient
            care, Denmark provides an ideal environment for professional and
            personal growth.
          </p>

          <p class="mb-6 text-lg text-gray-700">
            The Danish healthcare system is publicly funded and emphasizes
            preventive care, patient-centered treatment, and evidence-based
            medicine. Healthcare professionals enjoy competitive salaries,
            extensive professional development opportunities, and the chance to
            work with cutting-edge medical technology.
          </p>

          <h3
            class="mb-4 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl"
          >
            Healthcare System Overview
          </h3>
          <p class="mb-6 text-lg text-gray-700">
            Denmark's healthcare system is managed by five regions and operates
            under the principle of free and equal access to healthcare for all
            residents. The system includes hospitals, general practice,
            specialist care, and extensive community health services, providing
            diverse career opportunities for healthcare professionals.
          </p>

          <h3
            class="mb-4 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl"
          >
            Living in Denmark
          </h3>
          <p class="mb-6 text-lg text-gray-700">
            Denmark consistently ranks among the world's happiest countries,
            offering a high quality of life with excellent public
            transportation, beautiful cities, and a strong emphasis on
            sustainability. The concept of "hygge" - finding joy in everyday
            moments - is central to Danish culture, creating a welcoming
            environment for international professionals.
          </p>

          <h3
            class="mb-4 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl"
          >
            Professional Requirements
          </h3>
          <p class="text-lg text-gray-700">
            Filipino healthcare professionals interested in working in Denmark
            must have their qualifications recognized by the Danish Patient
            Safety Authority. Language requirements include proficiency in
            Danish, though many hospitals provide language training programs.
            FiNAN provides comprehensive support throughout the recognition and
            integration process.
          </p>
        </div>
      </div>
    </section>
    <Committee country="denmark" heading="Denmark" />

    <BlogRepresentation country="denmark" />

    <CTABanner />
  </main>
  <Footer />
</Layout>
