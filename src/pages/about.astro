---
import Layout from '../layouts/Layout.astro';
import TopBanner from '../components/TopBanner.astro';
import Navbar from '../components/Navbar.astro';
import PageHeader from '../components/PageHeader.astro';
import Footer from '../components/Footer.astro';
import heroImage from '../assets/images/hero-image.jpg';
import CTABanner from '../components/CTABanner.astro';
---

<Layout title="About the Philippines - FiNAN">
  <main>
    <TopBanner />
    <Navbar />
    <PageHeader
      title="About FiNAN"
      description="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
      backgroundImage={heroImage}
      backgroundAlt="Beautiful landscape representing the Philippines"
    />

    <!-- Additional content sections can be added here -->
    <section class="py-16 bg-white">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
        <div class="prose prose-lg max-w-none">
          <h2 class="text-3xl font-bold text-gray-900 mb-8">
            Welcome to the Philippines
          </h2>
          <p class="text-gray-700 mb-6">
            The Philippines, officially known as the Republic of the
            Philippines, is an archipelagic country in Southeast Asia. Situated
            in the western Pacific Ocean, it consists of about 7,641 islands
            that are broadly categorized under three main geographical divisions
            from north to south: Luzon, Visayas, and Mindanao.
          </p>

          <p class="text-gray-700 mb-6">
            Known for its diverse culture, beautiful landscapes, and warm
            hospitality, the Philippines has become home to many healthcare
            professionals who have made significant contributions to the Nordic
            healthcare systems.
          </p>

          <h3 class="text-2xl font-semibold text-gray-900 mb-4">
            Cultural Heritage
          </h3>
          <p class="text-gray-700 mb-6">
            The Philippines boasts a rich cultural heritage influenced by its
            indigenous roots, Spanish colonial history, American period, and
            modern global connections. This diversity is reflected in its
            languages, traditions, festivals, and cuisine.
          </p>

          <h3 class="text-2xl font-semibold text-gray-900 mb-4">
            Healthcare Excellence
          </h3>
          <p class="text-gray-700">
            Filipino healthcare professionals are renowned worldwide for their
            compassion, skill, and dedication. Many have chosen to build their
            careers in the Nordic countries, bringing their expertise and
            cultural values to enhance healthcare services across Denmark,
            Finland, Iceland, Norway, and Sweden.
          </p>
        </div>
      </div>
    </section>
    <CTABanner />
  </main>
  <Footer />
</Layout>
