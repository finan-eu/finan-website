---
import Layout from '../layouts/Layout.astro';
import TopBanner from '../components/TopBanner.astro';
import Navbar from '../components/Navbar.astro';
import PageHeader from '../components/PageHeader.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';
import heroImage from '../assets/images/hero-image.jpg';
import { faqs, faqIntro } from '../data/pages/faq/faqData';
---

<Layout title="FAQ - FiNAN">
  <main>
    <TopBanner />
    <Navbar />
    <PageHeader
      title="Frequently Asked Questions"
      description={faqIntro}
      backgroundImage={heroImage}
      backgroundAlt="Beautiful landscape representing the Philippines"
    />

    <!-- FAQ content sections -->
    <section class="bg-white py-16">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-6">
        <ol
          class="list-decimal space-y-12 pl-8 marker:text-2xl marker:font-semibold marker:text-gray-900"
        >
          {
            faqs.map((faq) => (
              <li class="border-b border-gray-200 pb-8 last:border-b-0">
                <h2 class="mb-4 text-2xl font-semibold text-gray-900 md:text-3xl">
                  {faq.question}
                </h2>
                <p class="text-base text-gray-700 md:text-lg">{faq.answer}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>
    <CTABanner />
    <Footer />
  </main>
</Layout>
