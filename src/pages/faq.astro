---
import Layout from '../layouts/Layout.astro';
import TopBanner from '../components/TopBanner.astro';
import Navbar from '../components/Navbar.astro';
import PageHeader from '../components/PageHeader.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import heroImage from '../assets/images/hero-image.jpg';
import { faqs, faqIntro, generateFAQSchema } from '../data/pages/faq/faqData';

const faqSchema = generateFAQSchema();
---

<Layout title="FAQ - FiNAN">
  <Fragment slot="head">
    <!-- FAQ Schema Markup for SEO and Rich Snippets -->
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <main>
    <!-- Skip to content link for keyboard navigation -->
    <a
      href="#faq-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:rounded-md focus:bg-blue-600 focus:px-4 focus:py-2 focus:text-white focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:outline-none"
    >
      Skip to FAQ content
    </a>
    <TopBanner />
    <Navbar />
    <PageHeader
      title="Frequently Asked Questions"
      description={faqIntro}
      backgroundImage={heroImage}
      backgroundAlt="Beautiful landscape representing the Philippines"
    />

    <!-- FAQ content sections -->
    <section
      id="faq-content"
      class="bg-gray-50 py-16"
      aria-labelledby="faq-heading"
    >
      <FAQAccordion faqs={faqs} />
    </section>
    <CTABanner />
    <Footer />
  </main>
</Layout>
