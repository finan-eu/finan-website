---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import TopBanner from '../components/TopBanner.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import EventSched from '../components/EventSched.astro';
import bannerImage from '../assets/images/events/banner-triennial-gathering-2026.jpg';
import scheduleBanner from '../assets/images/events/v2_banner-triennial-gathering-2026.png';
import { triennialGathering2026Schedule } from '../data/events/triennialGathering2026Schedule';
---

<Layout
  title="Triennial Gathering 2026 | FiNAN Conference"
  description="Join us for the FiNAN Triennial Gathering 2026 in Reykjavik, Iceland. Amplifying Voices: Navigating Equity, Leadership, and Global Migration. March 30 – April 1, 2026."
>
  <TopBanner />
  <Navbar />

  <!-- Event Header Section -->
  <section
    class="relative flex items-center justify-center py-16 text-white md:py-30"
  >
    <!-- Background Image -->
    <Image
      src={bannerImage}
      alt="Northern Lights over Reykjavik, Iceland"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
      format="webp"
      width={1920}
      height={1080}
    />

    <!-- Gray overlay -->
    <div class="absolute inset-0 bg-gray-900/70"></div>

    <!-- Content -->
    <div class="relative z-10 container mx-auto px-4 text-center">
      <!-- Conference Label -->
      <p class="mb-4 text-lg font-medium tracking-wide text-gray-200">
        FiNAN Conference
      </p>

      <!-- Main Title -->
      <h1 class="mb-6 text-5xl font-bold md:text-6xl lg:text-7xl">
        Triennial Gathering 2026
      </h1>

      <!-- Subtitle -->
      <p class="mb-8 text-xl text-gray-200 md:text-2xl">
        Amplifying Voices: Navigating Equity, Leadership, and Global Migration
      </p>

      <!-- Date and Location -->
      <div
        class="mb-10 flex flex-col items-center justify-center gap-4 text-gray-200 md:flex-row md:gap-8"
      >
        <div class="flex items-center gap-2">
          <img src="/icons/calendar-line.svg" alt="Calendar" class="h-5 w-5" />
          <span class="text-lg">March 30 – April 1, 2026</span>
        </div>
        <div class="flex items-center gap-2">
          <img src="/icons/map-pin-line.svg" alt="Location" class="h-5 w-5" />
          <span class="text-lg">Reykjavik, Iceland</span>
        </div>
      </div>

      <!-- Countdown Timer -->
      <div
        class="mb-10 inline-block rounded-lg border-2 border-white/30 bg-gray-600/50 p-6 backdrop-blur-sm"
      >
        <div class="flex gap-8" id="countdown">
          <div class="flex flex-col items-center">
            <span class="text-4xl font-bold md:text-5xl" id="days">00</span>
            <span class="mt-2 text-sm text-gray-300">Days</span>
          </div>
          <div class="flex flex-col items-center">
            <span class="text-4xl font-bold md:text-5xl" id="hours">00</span>
            <span class="mt-2 text-sm text-gray-300">Hours</span>
          </div>
          <div class="flex flex-col items-center">
            <span class="text-4xl font-bold md:text-5xl" id="minutes">00</span>
            <span class="mt-2 text-sm text-gray-300">Min</span>
          </div>
          <div class="flex flex-col items-center">
            <span class="text-4xl font-bold md:text-5xl" id="seconds">00</span>
            <span class="mt-2 text-sm text-gray-300">Secs</span>
          </div>
        </div>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col items-center justify-center gap-4 md:flex-row">
        <a
          href="#register"
          class="w-full rounded-full bg-white px-8 py-3 font-semibold text-gray-800 shadow-lg transition-all duration-200 hover:bg-gray-100 hover:shadow-xl md:w-auto"
        >
          Register Now
        </a>
        <a
          href="#schedule"
          class="w-full rounded-full border-2 border-white px-[30px] py-[10px] font-semibold text-white transition-all duration-200 hover:bg-white/10 md:w-auto"
        >
          View Schedule
        </a>
      </div>
    </div>
  </section>

  <!-- Event Information Section -->
  <section class="bg-white pt-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2
        class="pb-4 text-3xl font-bold tracking-tight text-gray-900 md:text-4xl"
      >
        Welcome to the Triennial Gathering 2026 in Reykjavik, Iceland!
      </h2>
      <p class="pb-4 text-lg text-gray-700">
        The <strong
          >Filipino Nurses Association in the Nordic Region (FiNAN)</strong
        > proudly invites you to our landmark event on <strong
          >March 30 – April 1, 2026</strong
        >, where we bring together <strong
          >Filipino Internationally Educated Nurses (IENs)</strong
        >, other internationally educated nurses, healthcare leaders,
        policy-makers, employers, and recruiters under one roof.
      </p>
      <p class="mb-10 text-lg text-gray-700">
        This gathering is more than a meeting, it is a platform for dialogue,
        collaboration, and action. Together, we will explore the most pressing
        issues shaping the nursing profession today, including workforce
        mobility, ethical recruitment, integration, retention, and the future of
        nursing in a globalized healthcare landscape.
      </p>
    </div>

    <!-- Event Schedule Section -->
    <section class="bg-white pb-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <!-- Schedule Banner Image -->
        <div>
          <Image
            src={scheduleBanner}
            alt="Triennial Gathering 2026 Schedule Banner"
            class="w-full rounded-lg"
            loading="lazy"
            format="webp"
          />
        </div>

        <h2
          class="pt-10 pb-6 text-3xl font-bold tracking-tight text-gray-900 md:text-4xl"
          id="schedule"
        >
          Schedule
        </h2>
      </div>
      <EventSched schedule={triennialGathering2026Schedule} />
    </section>

    <Footer />

    <script>
      // Countdown Timer Logic
      function updateCountdown() {
        const eventDate = new Date('2026-03-30T00:00:00').getTime();
        const now = new Date().getTime();
        const distance = eventDate - now;

        if (distance < 0) {
          document.getElementById('days')!.textContent = '00';
          document.getElementById('hours')!.textContent = '00';
          document.getElementById('minutes')!.textContent = '00';
          document.getElementById('seconds')!.textContent = '00';
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor(
          (distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60)
        );
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        document.getElementById('days')!.textContent = String(days).padStart(
          2,
          '0'
        );
        document.getElementById('hours')!.textContent = String(hours).padStart(
          2,
          '0'
        );
        document.getElementById('minutes')!.textContent = String(
          minutes
        ).padStart(2, '0');
        document.getElementById('seconds')!.textContent = String(
          seconds
        ).padStart(2, '0');
      }

      // Update countdown immediately and then every second
      updateCountdown();
      setInterval(updateCountdown, 1000);
    </script>
  </section>
</Layout>
