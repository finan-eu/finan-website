---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import TopBanner from '../components/TopBanner.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import EventSched from '../components/EventSched.astro';
import EventHeaderSection from '../components/EventHeaderSection.astro';
import scheduleBanner from '../assets/images/events/v2_banner-triennial-gathering-2026.png';
import { triennialGathering2026Schedule } from '../data/events/triennialGathering2026Schedule';
---

<Layout
  title="Triennial Gathering 2026 | FiNAN Conference"
  description="Join us for the FiNAN Triennial Gathering 2026 in Reykjavik, Iceland. Amplifying Voices: Navigating Equity, Leadership, and Global Migration. March 30 – April 1, 2026."
>
  <TopBanner />
  <Navbar />

  <EventHeaderSection />

  <!-- Event Information Section -->
  <section class="bg-white pt-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2
        class="pb-4 text-3xl font-bold tracking-tight text-gray-900 md:text-4xl"
      >
        Welcome to the Triennial Gathering 2026 in Reykjavik, Iceland!
      </h2>
      <p class="pb-4 text-lg text-gray-700">
        The <strong
          >Filipino Nurses Association in the Nordic Region (FiNAN)</strong
        > proudly invites you to our landmark event on <strong
          >March 30 – April 1, 2026</strong
        >, where we bring together <strong
          >Filipino Internationally Educated Nurses (IENs)</strong
        >, other internationally educated nurses, healthcare leaders,
        policy-makers, employers, and recruiters under one roof.
      </p>
      <p class="mb-10 text-lg text-gray-700">
        This gathering is more than a meeting, it is a platform for dialogue,
        collaboration, and action. Together, we will explore the most pressing
        issues shaping the nursing profession today, including workforce
        mobility, ethical recruitment, integration, retention, and the future of
        nursing in a globalized healthcare landscape.
      </p>
    </div>

    <!-- Event Schedule Section -->
    <section class="bg-white pb-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <!-- Schedule Banner Image -->
        <div>
          <Image
            src={scheduleBanner}
            alt="Triennial Gathering 2026 Schedule Banner"
            class="w-full rounded-lg"
            loading="lazy"
            format="webp"
          />
        </div>

        <h2
          class="pt-10 pb-6 text-3xl font-bold tracking-tight text-gray-900 md:text-4xl"
          id="schedule"
        >
          Schedule
        </h2>
      </div>
      <EventSched schedule={triennialGathering2026Schedule} />
    </section>

    <Footer />
  </section>
</Layout>
