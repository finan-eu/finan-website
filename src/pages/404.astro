---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Blog from '../components/Blog.astro';
import RegistrationSection from '../components/RegistrationSection.astro';
import CTABanner from '../components/CTABanner.astro';
---

<Layout title="Page Not Found | FiNAN">
  <main class="flex min-h-screen flex-col bg-white">
    <Navbar />

    <section class="flex flex-1 items-center bg-white py-24">
      <div
        class="mx-auto flex w-full max-w-7xl flex-col items-center gap-10 px-6 text-center"
      >
        <span
          class="rounded-full bg-blue-100 px-4 py-1 text-sm font-semibold tracking-widest text-blue-900 uppercase"
        >
          404 error
        </span>
        <div class="flex flex-col items-center gap-6">
          <h1 class="text-4xl font-bold text-gray-900 sm:text-5xl">
            We can't find the page you're looking for
          </h1>
          <p class="max-w-2xl text-lg text-gray-600">
            The link may be broken or the page might have been moved. Let's get
            you back to the information and support you need from FiNAN.
          </p>
        </div>
        <div
          class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-center"
        >
          <a
            href="/"
            class="btn-scale inline-flex items-center justify-center rounded-full bg-blue-900 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-blue-800"
          >
            Go back to homepage
          </a>
          <a
            href="/contact"
            class="btn-scale inline-flex items-center justify-center rounded-full border border-blue-200 px-6 py-3 text-base font-semibold text-blue-900 transition-colors hover:border-blue-900 hover:bg-blue-50"
          >
            Contact Us
          </a>
        </div>
      </div>
    </section>
    <Blog />
    <RegistrationSection />
    <CTABanner />
  </main>
  <Footer />
</Layout>
