---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found | FiNAN">
  <main class="flex min-h-screen flex-col bg-white">
    <Navbar />

    <section
      class="flex flex-1 items-center bg-gradient-to-b from-blue-50 via-white to-white py-24"
    >
      <div
        class="mx-auto flex w-full max-w-screen-xl flex-col items-center gap-10 px-6 text-center"
      >
        <span
          class="rounded-full bg-blue-100 px-4 py-1 text-sm font-semibold tracking-widest text-blue-900 uppercase"
        >
          404 error
        </span>
        <div class="flex flex-col items-center gap-6">
          <h1 class="text-4xl font-bold text-gray-900 sm:text-5xl">
            We can't seem to find the page you're looking for
          </h1>
          <p class="max-w-2xl text-lg text-gray-600">
            The link may be broken or the page might have been moved. Let's get
            you back to the information and support you need from FiNAN.
          </p>
        </div>
        <div
          class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-center"
        >
          <a
            href="/"
            class="inline-flex items-center justify-center rounded-full bg-blue-900 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-blue-800"
          >
            Go back home
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center rounded-full border border-blue-200 px-6 py-3 text-base font-semibold text-blue-900 transition-colors hover:border-blue-900 hover:bg-blue-50"
          >
            Contact support
          </a>
        </div>
        <div
          class="max-w-2xl rounded-2xl border border-blue-100 bg-white p-6 text-left shadow-sm"
        >
          <h2 class="text-lg font-semibold text-gray-900">
            Need something else?
          </h2>
          <ul class="mt-3 space-y-2 text-gray-600">
            <li>
              <a
                class="transition-colors hover:text-blue-900"
                href="/guides-resources"
              >
                Browse our guides & resources for licensing and integration tips
              </a>
            </li>
            <li>
              <a
                class="transition-colors hover:text-blue-900"
                href="/membership"
              >
                Learn how FiNAN membership supports Filipino nurses across the
                Nordics
              </a>
            </li>
            <li>
              <a
                class="transition-colors hover:text-blue-900"
                href="/representation"
              >
                Connect with your local FiNAN representation for events and
                community
              </a>
            </li>
          </ul>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
