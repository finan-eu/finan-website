---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getAllPostSlugs, getPostBySlug } from '../../lib/ghost';

// Generate static paths for all blog posts
export async function getStaticPaths() {
  const slugs = await getAllPostSlugs();

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

// Get the slug from URL params
const { slug } = Astro.params;

// Fetch the post data
const post = await getPostBySlug(slug);

// If post doesn't exist, redirect to 404
if (!post) {
  return Astro.redirect('/404');
}

// Helper function to format date
function formatDate(dateString: string) {
  return new Date(dateString).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

// Get author name
const authorName =
  post.authors && post.authors.length > 0 ? post.authors[0].name : 'FiNAN Team';
---

<Layout>
  <Navbar />

  <main class="bg-white py-16 md:py-24">
    <article class="mx-auto max-w-4xl px-6">
      <!-- Back to Blog Link -->
      <div class="mb-8">
        <a
          href="/blog"
          class="inline-flex items-center font-medium text-gray-600 transition-colors hover:text-gray-900"
        >
          <svg
            class="mr-2 h-4 w-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 19l-7-7 7-7"></path>
          </svg>
          Back to Blog
        </a>
      </div>

      <!-- Featured Image -->
      {
        post.feature_image && (
          <div class="mb-8 overflow-hidden rounded-lg">
            <img
              src={post.feature_image}
              alt={post.title}
              class="h-auto w-full"
            />
          </div>
        )
      }

      <!-- Post Header -->
      <header class="mb-8">
        <!-- Tags -->
        {
          post.tags && post.tags.length > 0 && (
            <div class="mb-4 flex flex-wrap gap-2">
              {post.tags.map((tag) => (
                <span class="rounded bg-gray-100 px-3 py-1 text-sm font-medium text-gray-900">
                  {tag.name}
                </span>
              ))}
            </div>
          )
        }

        <!-- Title -->
        <h1 class="mb-4 text-4xl font-bold text-gray-900 md:text-5xl">
          {post.title}
        </h1>

        <!-- Meta Information -->
        <div class="flex items-center gap-4 text-gray-600">
          <span>By {authorName}</span>
          <span>•</span>
          <time datetime={post.published_at}>
            {formatDate(post.published_at)}
          </time>
        </div>

        <!-- Excerpt -->
        {
          post.excerpt && (
            <p class="mt-4 text-xl leading-relaxed text-gray-700">
              {post.excerpt}
            </p>
          )
        }
      </header>

      <!-- Post Content -->
      <div
        class="prose prose-lg prose-gray prose-headings:font-bold prose-headings:text-gray-900 prose-p:text-gray-700 prose-a:text-blue-900 prose-a:no-underline hover:prose-a:underline prose-strong:text-gray-900 prose-img:rounded-lg max-w-none"
        set:html={post.html}
      />

      <!-- Divider -->
      <hr class="my-12 border-gray-200" />

      <!-- Back to Blog Button -->
      <div class="text-center">
        <a
          href="/blog"
          class="inline-flex items-center rounded-lg border-2 border-blue-900 px-8 py-3 font-medium text-blue-900 transition-all duration-300 hover:bg-blue-900 hover:text-white"
        >
          <svg
            class="mr-2 h-4 w-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 19l-7-7 7-7"></path>
          </svg>
          Back to All Posts
        </a>
      </div>
    </article>
  </main>

  <Footer />
</Layout>

<style>
  /* Custom styles for Ghost content */
  .prose {
    @apply text-lg;
  }

  .prose h2 {
    @apply mt-8 mb-4 text-3xl;
  }

  .prose h3 {
    @apply mt-6 mb-3 text-2xl;
  }

  .prose h4 {
    @apply mt-4 mb-2 text-xl;
  }

  .prose p {
    @apply mb-4 leading-relaxed;
  }

  .prose ul,
  .prose ol {
    @apply mb-4 ml-6;
  }

  .prose li {
    @apply mb-2;
  }

  .prose blockquote {
    @apply border-l-4 border-blue-900 pl-4 text-gray-700 italic;
  }

  .prose code {
    @apply rounded bg-gray-100 px-1 py-0.5 font-mono text-sm;
  }

  .prose pre {
    @apply mb-4 overflow-x-auto rounded-lg bg-gray-900 p-4;
  }

  .prose pre code {
    @apply bg-transparent p-0 text-gray-100;
  }
</style>
