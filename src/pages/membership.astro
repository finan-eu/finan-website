---
import Layout from '../layouts/Layout.astro';
import TopBanner from '../components/TopBanner.astro';
import Navbar from '../components/Navbar.astro';
import PageHeader from '../components/PageHeader.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero-image.jpg';
import arcadaLogo from '../assets/images/partners/arcada-logo.png';
import euResearchLogo from '../assets/images/partners/eu-research-innovation.png';
import fdnLogo from '../assets/images/partners/filipino-nursing-diaspora-network.png';
import finnishGovtEmblem from '../assets/images/partners/finnish_government_emblem.svg';
import ianpcLogo from '../assets/images/partners/ianpc.png';
import moniheliLogo from '../assets/images/partners/moniheli-logo.png';
import oamkLogo from '../assets/images/partners/oamk-logo.png';
import siennaLogo from '../assets/images/partners/sienna-logo.png';
import wsdnLogo from '../assets/images/partners/wsdn-logo.png';
---

<Layout title="Membership - FiNAN">
  <main>
    <TopBanner />
    <Navbar />
    <PageHeader
      title="Membership"
      description="The Filipino Nurses Association in the Nordic Region (FiNAN) is the only regional registered non-profit organization that represents and bridges Filipino Nurses in the Nordic Region."
      backgroundImage={heroImage}
      backgroundAlt="Filipino healthcare professionals in the Nordic countries"
    />

    <!-- Membership Registration Section -->
    <section class="bg-gray-50 py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <div class="space-y-8">
          <h2
            class="mb-4 text-3xl font-bold tracking-tight text-gray-900 md:text-4xl"
          >
            Membership Registration
          </h2>
          <ul
            class="list-outside list-disc space-y-2 pl-6 text-lg text-gray-700"
          >
            <li>
              Membership is open to individuals in the Nordic countries who are
              licensed nurses or currently pursuing their nursing license.
            </li>
            <li>Annual membership fee: 20 euros.</li>
            <li>
              For membership inquiries, email us at <a
                href="mailto:info@finan.eu.com"
                class="text-blue-600 underline hover:text-blue-800"
              >
                info@finan.eu.com
              </a>
            </li>
          </ul>
          <p class="text-lg font-bold text-gray-700">
            Click the button below to open FiNAN's membership registration form.
          </p>
          <div>
            <a
              href="https://membership.finan.eu.com"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block rounded-full bg-blue-900 px-8 py-4 text-lg font-semibold text-white shadow-lg transition-all duration-200 hover:bg-blue-800 hover:shadow-xl"
            >
              Register as a Member
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Membership content -->
    <section class="bg-white py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <div class="space-y-12">
          <div>
            <h2
              class="mb-4 text-3xl font-bold tracking-tight text-gray-900 md:text-4xl"
            >
              Representation
            </h2>
            <p class="text-lg text-gray-700">
              The Filipino Nurses Association in the Nordic Region (FiNAN) is a
              registered non-profit organization in the Nordic Region
              representing the voice of Filipino Nurses for important issues in
              the form of integration plan, migration issues, equality,
              healthcare and workplace protection to the policy and
              decision-makers.
            </p>
          </div>

          <div>
            <h2
              class="mb-4 text-3xl font-bold tracking-tight text-gray-900 md:text-4xl"
            >
              Opportunities
            </h2>
            <p class="mb-6 text-lg text-gray-700">
              FiNAN is actively invited in events, seminars, conferences both
              locally and internationally. You can be part of these
              opportunities.
            </p>
            <ul class="list-inside list-disc space-y-2 text-lg text-gray-700">
              <li>Discounted entries in the Annual General Assembly</li>
              <li>
                Updates in the welfare of Filipino Nurses in the Nordic
                Countries
              </li>
              <li>Nordic Puls Digital Magazine</li>
              <li>
                Advice and Councelling on Professional Development (Master's and
                Doctorate Degree)
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Partners Section -->
    <section class="bg-white pb-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <!-- Header -->
        <div class="mb-16">
          <h2 class="mb-4 text-3xl font-bold text-gray-900 md:text-4xl">
            Our Partners in Healthcare, Education & Policy
          </h2>
        </div>

        <!-- Partner Logos Grid -->
        <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
          <div class="flex items-center justify-center px-4">
            <Image
              src={finnishGovtEmblem}
              alt="Finnish Government"
              class="h-16 w-auto object-contain md:h-20"
            />
          </div>

          <!-- OAMK -->
          <div class="flex items-center justify-center px-4">
            <Image
              src={oamkLogo}
              alt="Oulu University of Applied Sciences"
              class="max-h-16 w-auto object-contain md:max-h-20"
            />
          </div>

          <!-- Arcada -->
          <div class="flex items-center justify-center px-4">
            <Image
              src={arcadaLogo}
              alt="Arcada University of Applied Sciences"
              class="max-h-20 w-auto object-contain md:max-h-25"
            />
          </div>

          <!-- EU Research -->
          <div class="flex items-center justify-center px-4">
            <Image
              src={euResearchLogo}
              alt="European Union Research and Innovation"
              class="max-h-25 w-auto object-contain md:max-h-30"
            />
          </div>

          <!-- Moniheli -->
          <div class="flex items-center justify-center px-4">
            <Image
              src={moniheliLogo}
              alt="Moniheli"
              class="max-h-5 w-auto object-contain md:max-h-8"
            />
          </div>

          <!-- Filipino Nursing Diaspora Network -->
          <div class="flex items-center justify-center px-4">
            <Image
              src={fdnLogo}
              alt="Filipino Nursing Diaspora Network"
              class="max-h-16 w-auto object-contain md:max-h-20"
            />
          </div>

          <!-- SIENNA -->
          <div class="flex items-center justify-center px-4">
            <Image
              src={siennaLogo}
              alt="Society of Internationally Educated Nurses in North America"
              class="max-h-18 w-auto object-contain md:max-h-25"
            />
          </div>

          <!-- IANPC -->
          <div class="flex items-center justify-center px-4">
            <Image
              src={ianpcLogo}
              alt="International Assembly for National Nursing Associations"
              class="max-h-18 w-auto object-contain md:max-h-25"
            />
          </div>

          <!-- WSDN -->
          <div class="flex items-center justify-center px-4">
            <Image
              src={wsdnLogo}
              alt="World Sustainable Development Network"
              class="max-h-18 w-auto object-contain md:max-h-25"
            />
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
