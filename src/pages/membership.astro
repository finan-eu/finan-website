---
import Layout from '../layouts/Layout.astro';
import TopBanner from '../components/TopBanner.astro';
import Navbar from '../components/Navbar.astro';
import PageHeader from '../components/PageHeader.astro';
import Footer from '../components/Footer.astro';
import heroImage from '../assets/images/hero-image.jpg';
---

<Layout title="Membership - FiNAN">
  <main>
    <TopBanner />
    <Navbar />
    <PageHeader
      title="Membership"
      description="Join the Filipino Nurses Association of the Nordic countries and connect with a vibrant community of healthcare professionals."
      backgroundImage={heroImage}
      backgroundAlt="Filipino healthcare professionals in the Nordic countries"
    />

    <!-- Additional content sections can be added here -->
    <section class="bg-white py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <header class="max-w-2xl">
          <h2
            class="text-3xl font-bold tracking-tight text-gray-900 md:text-4xl"
          >
            Join Our Community
          </h2>
        </header>

        <div class="mt-4">
          <p class="mb-6 text-lg text-gray-700">
            Be a member and join a supportive network of Filipino healthcare
            professionals working across the Nordic countries. Our membership
            provides access to professional development opportunities,
            networking events, and valuable resources to help you thrive in your
            career and personal life in the Nordic region.
          </p>

          <p class="mb-6 text-lg text-gray-700">
            Whether you're already working in Denmark, Finland, Iceland, Norway,
            or Sweden, or planning to make the transition, FiNAN membership
            offers the support and connections you need to succeed in your
            healthcare career.
          </p>

          <h3
            class="mb-4 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl"
          >
            Membership Benefits
          </h3>
          <p class="mb-6 text-lg text-gray-700">
            As a FiNAN member, you'll gain access to exclusive resources
            including professional development workshops, credential recognition
            guidance, language learning support, and mentorship programs. Our
            community events provide opportunities to connect with fellow
            professionals and build lasting relationships across the Nordic
            countries.
          </p>

          <h3
            class="mb-4 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl"
          >
            How to Join
          </h3>
          <p class="text-lg text-gray-700">
            Membership is open to all Filipino healthcare professionals working
            or planning to work in the Nordic countries. Join us today and
            become part of a community dedicated to supporting each other's
            professional growth and personal well-being in the Nordic region.
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
