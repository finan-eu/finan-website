---
import { Image } from 'astro:assets';
import {
  workingCommitteeConfigs,
  type WorkingCommitteeConfig,
  type WorkingCommitteeCountry,
  type WorkingCommitteeMember,
} from '../data/representation/working-committee';

interface WorkingCommitteeProps extends Partial<WorkingCommitteeConfig> {
  country?: WorkingCommitteeCountry;
  heading?: string;
  description?: string;
}

const fallbackConfig: WorkingCommitteeConfig = {
  members: [
    {
      name: 'Full name',
      role: 'Job title',
      bio: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique.',
      imageAlt: 'Placeholder portrait',
      linkedinUrl: '#',
    },
  ] satisfies ReadonlyArray<WorkingCommitteeMember>,
};

const defaultHeading = 'Working Committee';

const props = Astro.props as WorkingCommitteeProps;
const baseConfig = props.country
  ? workingCommitteeConfigs[props.country]
  : undefined;

const heading = props.heading ?? defaultHeading;
const description = props.description;
const members = props.members ?? baseConfig?.members ?? fallbackConfig.members;
---

<section class="bg-white">
  <div class="mx-auto max-w-4xl px-6 pb-16">
    <header class="max-w-4xl">
      <h2
        class="mb-4 text-3xl font-bold tracking-tight text-gray-900 md:text-4xl"
      >
        {heading}
      </h2>
      {description && <p class="mt-4 text-lg text-gray-700">{description}</p>}
    </header>

    <div class="mt-12 flex flex-wrap gap-10">
      {
        members.map((member) => (
          <article class="flex max-w-sm min-w-xs flex-1 items-start gap-6">
            <div class="flex-shrink-0">
              <div class="relative h-24 w-24 overflow-hidden rounded-full border border-gray-200 bg-gray-200">
                {member.imageSrc ? (
                  typeof member.imageSrc === 'string' ? (
                    <img
                      src={member.imageSrc}
                      alt={member.imageAlt}
                      class="h-full w-full object-cover"
                      loading="lazy"
                    />
                  ) : (
                    <Image
                      src={member.imageSrc}
                      alt={member.imageAlt}
                      class="h-full w-full object-cover"
                      loading="lazy"
                      width={96}
                      height={96}
                    />
                  )
                ) : (
                  <div class="flex h-full w-full items-center justify-center bg-gray-200">
                    <svg
                      class="h-8 w-8 text-gray-400"
                      viewBox="0 0 48 48"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M40 6a2 2 0 0 1 2 2v32a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h32Zm-1 28-7.6-10.2-3.4 4.5L20 18 9 35h30ZM17.5 14.5a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7Z" />
                    </svg>
                  </div>
                )}
              </div>
            </div>

            <div class="min-w-0 flex-1">
              <h3 class="mb-1 text-xl font-bold text-gray-900">
                {member.name}
              </h3>
              <p class="mb-2 text-lg text-gray-900">{member.role}</p>
              {member.affiliations && (
                <p class="mb-3 text-sm text-gray-900">{member.affiliations}</p>
              )}
              <p class="text-sm leading-relaxed text-gray-700">{member.bio}</p>

              {member.linkedinUrl && (
                <div class="mt-4">
                  <a
                    href={member.linkedinUrl}
                    aria-label={`${member.name}'s LinkedIn profile`}
                    class="inline-flex text-gray-500 transition-colors duration-200 hover:text-gray-900 focus:outline-none focus-visible:text-gray-900"
                  >
                    <span class="sr-only">{member.name} on LinkedIn</span>
                    <img
                      src="/icons/socmed/linkedin.svg"
                      alt=""
                      class="h-7 w-7"
                      aria-hidden="true"
                      loading="lazy"
                    />
                  </a>
                </div>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
