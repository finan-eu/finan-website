---
// CTABanner.astro - Call to Action banner section
import { ctaBannerConfig } from '../data/ctaBannerConfig';
---

<section class="bg-gray-800 py-16">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-8">
      <!-- Left side - Main CTA content -->
      <div class="flex-1 text-center lg:text-left">
        <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4 max-w-2xl">
          {ctaBannerConfig.heading}
        </h2>
        <p class="text-lg text-gray-300 max-w-2xl">
          {ctaBannerConfig.description}
        </p>
      </div>

      <!-- Right side - CTA buttons -->
      <div class="flex flex-col sm:flex-row gap-4 lg:flex-shrink-0">
        <a
          href={ctaBannerConfig.buttons.secondary.href}
          class="border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-gray-800 transition-colors duration-200 text-center"
        >
          {ctaBannerConfig.buttons.secondary.text}
        </a>
        <a
          href={ctaBannerConfig.buttons.primary.href}
          class="bg-white text-gray-800 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors duration-200 text-center"
        >
          {ctaBannerConfig.buttons.primary.text}
        </a>
      </div>
    </div>
  </div>
</section>
