---
// CTABanner.astro - Call to Action banner section
import { ctaBannerConfig } from '../data/ctaBannerConfig';
---

<section class="bg-gray-800 py-16">
  <div class="mx-auto max-w-screen-xl px-6">
    <div class="flex flex-col items-center justify-between gap-8 lg:flex-row">
      <!-- Left side - Main CTA content -->
      <div class="flex-1 text-center lg:text-left">
        <h2
          class="mb-4 max-w-2xl text-3xl leading-tight font-bold text-white lg:text-4xl"
        >
          {ctaBannerConfig.heading}
        </h2>
        <p class="max-w-2xl text-lg text-gray-300">
          {ctaBannerConfig.description}
        </p>
      </div>

      <!-- Right side - CTA buttons -->
      <div
        class="flex w-full flex-col gap-4 sm:w-auto sm:flex-row lg:flex-shrink-0"
      >
        <a
          href={ctaBannerConfig.buttons.primary.href}
          class="inline-block w-full rounded-full bg-white px-8 py-3 text-center font-semibold text-gray-800 transition-colors duration-200 hover:bg-gray-100 sm:w-auto"
        >
          {ctaBannerConfig.buttons.primary.text}
        </a>
        <!-- <a
          href={ctaBannerConfig.buttons.secondary.href}
          class="inline-block w-full rounded-full border-2 border-white px-8 py-3 text-center font-semibold text-white transition-colors duration-200 hover:bg-white hover:text-gray-800 sm:w-auto"
        >
          {ctaBannerConfig.buttons.secondary.text}
        </a> -->
      </div>
    </div>
  </div>
</section>
