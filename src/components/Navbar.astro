---
// Navbar.astro - Main navigation component
import { Image } from 'astro:assets';
import finanLogo from '../assets/finan-logo.svg';
---

<nav class="bg-white shadow-sm border-b border-gray-200 relative z-50">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="flex items-center justify-between h-20">
      <!-- Logo/Brand -->
      <div class="flex-shrink-0">
        <a href="/" class="block">
          <Image
            src={finanLogo}
            alt="FiNAN Logo"
            class="h-12 w-auto"
            loading="eager"
          />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:block">
        <div class="ml-10 flex items-baseline space-x-4">
          <a
            href="/guides"
            class="text-gray-700 hover:text-gray-900 px-3 py-2 text-lg font-medium transition-colors"
          >
            Guides & Resources
          </a>
          <a
            href="/news"
            class="text-gray-700 hover:text-gray-900 px-3 py-2 text-lg font-medium transition-colors"
          >
            News & Events
          </a>
          <a
            href="/faqs"
            class="text-gray-700 hover:text-gray-900 px-3 py-2 text-lg font-medium transition-colors"
          >
            FAQs
          </a>
          <a
            href="/about"
            class="text-gray-700 hover:text-gray-900 px-3 py-2 text-lg font-medium transition-colors"
          >
            About
          </a>
          <a
            href="/contact"
            class="text-gray-700 hover:text-gray-900 px-3 py-2 text-lg font-medium transition-colors"
          >
            Contact
          </a>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="hidden md:flex items-center space-x-4">
        <a
          href="/donate"
          class="border-1 border-gray-300 text-gray-700 px-4 py-2 rounded-md text-lg font-medium hover:bg-gray-50 transition-colors"
        >
          Donate
        </a>
        <a
          href="/membership"
          class="border-1 border-gray-900 bg-gray-900 text-white px-4 py-2 rounded-md text-lg font-medium hover:bg-gray-800 transition-colors"
        >
          Become a Member
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden">
        <button
          id="mobile-menu-button"
          type="button"
          class="text-gray-700 hover:text-gray-900 focus:outline-none focus:ring-2 focus:ring-gray-500 p-2"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <span class="sr-only">Open main menu</span>
          <!-- Hamburger icon -->
          <svg
            class="block h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div class="md:hidden hidden" id="mobile-menu">
      <div class="pt-2 pb-3 space-y-1 border-t border-gray-200">
        <a
          href="/about"
          class="text-gray-700 hover:text-gray-900 block py-2 text-lg font-medium"
        >
          About Us
        </a>
        <a
          href="/guides"
          class="text-gray-700 hover:text-gray-900 block py-2 text-lg font-medium"
        >
          Guides & Resources
        </a>
        <a
          href="/news"
          class="text-gray-700 hover:text-gray-900 block py-2 text-lg font-medium"
        >
          News & Events
        </a>
        <a
          href="/faqs"
          class="text-gray-700 hover:text-gray-900 block py-2 text-lg font-medium"
        >
          FAQs
        </a>
        <a
          href="/contact"
          class="text-gray-700 hover:text-gray-900 block py-2 text-lg font-medium"
        >
          Contact Us
        </a>
        <div class="pt-4 pb-3 border-t border-gray-200">
          <div class="flex flex-col space-y-2">
            <a
              href="/donate"
              class="border border-gray-300 text-gray-700 px-4 py-2 rounded-md text-lg font-medium hover:bg-gray-50 transition-colors text-center"
            >
              Donate
            </a>
            <a
              href="/membership"
              class="border border-gray-900 bg-gray-900 text-white px-4 py-2 rounded-md text-lg font-medium hover:bg-gray-800 transition-colors text-center"
            >
              Become a Member
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>

<script src="/src/scripts/mobile-menu.js"></script>
