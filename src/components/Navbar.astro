---
// Navbar.astro - Main navigation component
import { Image } from 'astro:assets';
import finanLogo from '../assets/finan-logo.svg';
---

<nav class="bg-white shadow-sm border-b border-gray-200 relative z-50 py-2">
  <div class="max-w-screen-2xl mx-auto px-6">
    <div class="flex items-center justify-between h-20">
      <!-- Logo/Brand -->
      <div class="flex-shrink-0">
        <a href="/" class="block">
          <Image
            src={finanLogo}
            alt="FiNAN Logo"
            class="h-12 w-auto"
            loading="eager"
          />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden lg:block">
        <div class="ml-10 flex items-baseline space-x-4">
          <a
            href="/guides-resources"
            class="text-gray-700 hover:text-gray-900 px-3 py-2 text-lg font-medium transition-colors"
          >
            Guides & Resources
          </a>
          <a
            href="/news"
            class="text-gray-700 hover:text-gray-900 px-3 py-2 text-lg font-medium transition-colors"
          >
            News & Events
          </a>
          <a
            href="/faq"
            class="text-gray-700 hover:text-gray-900 px-3 py-2 text-lg font-medium transition-colors"
          >
            FAQs
          </a>
          <!-- Chapters Dropdown -->
          <div class="relative" id="chapters-dropdown">
            <button
              type="button"
              class="text-gray-700 hover:text-gray-900 px-3 py-2 text-lg font-medium transition-colors flex items-center cursor-pointer"
              id="chapters-button"
              aria-expanded="false"
              aria-haspopup="true"
            >
              Chapters
              <svg
                class="ml-1 h-4 w-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div
              class="absolute left-0 mt-2 w-48 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 opacity-0 invisible transform scale-95 transition-all duration-200 ease-out z-50 overflow-hidden"
              id="chapters-menu"
              role="menu"
              aria-orientation="vertical"
              aria-labelledby="chapters-button"
            >
              <div class="py-0" role="none">
                <a
                  href="/chapters/denmark"
                  class="text-gray-700 hover:bg-gray-100 hover:text-gray-900 block px-4 py-2 text-lg"
                  role="menuitem">Denmark</a
                >
                <a
                  href="/chapters/faroe-islands"
                  class="text-gray-700 hover:bg-gray-100 hover:text-gray-900 block px-4 py-2 text-lg"
                  role="menuitem">Faroe Islands</a
                >
                <a
                  href="/chapters/finland"
                  class="text-gray-700 hover:bg-gray-100 hover:text-gray-900 block px-4 py-2 text-lg"
                  role="menuitem">Finland</a
                >
                <a
                  href="/chapters/greenland"
                  class="text-gray-700 hover:bg-gray-100 hover:text-gray-900 block px-4 py-2 text-lg"
                  role="menuitem">Greenland</a
                >
                <a
                  href="/chapters/iceland"
                  class="text-gray-700 hover:bg-gray-100 hover:text-gray-900 block px-4 py-2 text-lg"
                  role="menuitem">Iceland</a
                >
                <a
                  href="/chapters/norway"
                  class="text-gray-700 hover:bg-gray-100 hover:text-gray-900 block px-4 py-2 text-lg"
                  role="menuitem">Norway</a
                >
                <a
                  href="/chapters/sweden"
                  class="text-gray-700 hover:bg-gray-100 hover:text-gray-900 block px-4 py-2 text-lg"
                  role="menuitem">Sweden</a
                >
              </div>
            </div>
          </div>
          <a
            href="/about"
            class="text-gray-700 hover:text-gray-900 px-3 py-2 text-lg font-medium transition-colors"
          >
            About
          </a>
          <a
            href="/contact"
            class="text-gray-700 hover:text-gray-900 px-3 py-2 text-lg font-medium transition-colors"
          >
            Contact
          </a>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="hidden lg:flex items-center space-x-4">
        <a
          href="/donate"
          class="border-1 border-gray-300 text-gray-700 px-4 py-2 rounded-md text-lg font-medium hover:bg-gray-50 transition-colors"
        >
          Donate
        </a>
        <a
          href="/membership"
          class="border-1 border-gray-900 bg-gray-900 text-white px-4 py-2 rounded-md text-lg font-medium hover:bg-gray-800 transition-colors"
        >
          Become a Member
        </a>
      </div>

      <!-- Mobile CTA and menu button -->
      <div class="lg:hidden flex items-center space-x-3">
        <a
          href="/membership"
          class="bg-gray-900 text-white px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-800 transition-colors"
        >
          Become a Member
        </a>
        <button
          id="mobile-menu-button"
          type="button"
          class="bg-gray-200 text-gray-900 hover:bg-gray-500 focus:outline-none focus:ring-2 focus:ring-gray-500 p-2 rounded"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <span class="sr-only">Open main menu</span>
          <!-- Hamburger icon -->
          <svg
            class="block h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div class="lg:hidden hidden" id="mobile-menu">
      <div class="pt-2 pb-3 space-y-1 border-t border-gray-200">
        <a
          href="/about"
          class="text-gray-700 hover:text-gray-900 block py-2 text-lg font-medium"
        >
          About Us
        </a>
        <a
          href="/guides"
          class="text-gray-700 hover:text-gray-900 block py-2 text-lg font-medium"
        >
          Guides & Resources
        </a>
        <a
          href="/news"
          class="text-gray-700 hover:text-gray-900 block py-2 text-lg font-medium"
        >
          News & Events
        </a>
        <a
          href="/faqs"
          class="text-gray-700 hover:text-gray-900 block py-2 text-lg font-medium"
        >
          FAQs
        </a>
        <!-- Mobile Chapters Dropdown -->
        <div class="block">
          <button
            type="button"
            class="text-gray-700 hover:text-gray-900 w-full text-left py-2 text-lg font-medium flex items-center justify-between"
            id="mobile-chapters-button"
            aria-expanded="false"
          >
            Chapters
            <svg
              class="h-4 w-4 transform transition-transform duration-200"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              id="mobile-chapters-icon"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="pl-4 space-y-1 hidden" id="mobile-chapters-menu">
            <a
              href="/chapters/denmark"
              class="text-gray-600 hover:text-gray-900 block py-2 text-lg"
              >Denmark</a
            >
            <a
              href="/chapters/faroe-islands"
              class="text-gray-600 hover:text-gray-900 block py-2 text-lg"
              >Faroe Islands</a
            >
            <a
              href="/chapters/finland"
              class="text-gray-600 hover:text-gray-900 block py-2 text-lg"
              >Finland</a
            >
            <a
              href="/chapters/greenland"
              class="text-gray-600 hover:text-gray-900 block py-2 text-lg"
              >Greenland</a
            >
            <a
              href="/chapters/iceland"
              class="text-gray-600 hover:text-gray-900 block py-2 text-lg"
              >Iceland</a
            >
            <a
              href="/chapters/norway"
              class="text-gray-600 hover:text-gray-900 block py-2 text-lg"
              >Norway</a
            >
            <a
              href="/chapters/sweden"
              class="text-gray-600 hover:text-gray-900 block py-2 text-lg"
              >Sweden</a
            >
          </div>
        </div>
        <a
          href="/contact"
          class="text-gray-700 hover:text-gray-900 block py-2 text-lg font-medium"
        >
          Contact Us
        </a>
        <div class="pt-4 pb-3 border-t border-gray-200">
          <div class="flex flex-col space-y-2">
            <a
              href="/donate"
              class="border border-gray-300 text-gray-700 px-4 py-2 rounded-md text-lg font-medium hover:bg-gray-50 transition-colors text-center"
            >
              Donate
            </a>
            <a
              href="/membership"
              class="border border-gray-900 bg-gray-900 text-white px-4 py-2 rounded-md text-lg font-medium hover:bg-gray-800 transition-colors text-center"
            >
              Become a Member
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>

<script is:inline src="/js/navbar.js"></script>
