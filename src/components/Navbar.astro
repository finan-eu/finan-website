---
// Navbar.astro - Main navigation component
import { Image } from 'astro:assets';
import finanLogo from '../assets/finan-logo.svg';
---

<nav class="relative z-50 border-b border-gray-200 bg-white py-2 shadow-sm">
  <div class="mx-auto max-w-screen-2xl px-6">
    <div class="flex h-14 items-center justify-between xl:h-20">
      <!-- Logo/Brand -->
      <div class="flex-shrink-0">
        <a href="/" class="block">
          <Image
            src={finanLogo}
            alt="FiNAN Logo"
            class="h-9 w-auto xl:h-12"
            loading="eager"
          />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden xl:block">
        <div class="flex items-baseline space-x-4">
          <a
            href="/about"
            class="rounded-md px-3 py-2 text-lg font-medium text-gray-700 transition-colors hover:bg-blue-50 hover:text-gray-900"
          >
            About
          </a>
          <!-- Chapters Dropdown -->
          <div class="group relative" id="chapters-dropdown">
            <button
              type="button"
              class="flex cursor-pointer items-center rounded-md px-3 py-2 text-lg font-medium text-gray-700 transition-colors hover:bg-blue-50 hover:text-gray-900"
              id="chapters-button"
              aria-expanded="false"
              aria-haspopup="true"
            >
              Chapters
              <svg
                class="ml-1 h-4 w-4 transition-transform duration-200 ease-out group-hover:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div
              class="ring-opacity-5 invisible absolute left-0 z-50 mt-2 w-56 scale-95 transform overflow-hidden rounded-md bg-white opacity-0 shadow-lg ring-1 ring-black transition-all duration-200 ease-out group-hover:visible group-hover:scale-100 group-hover:opacity-100"
              id="chapters-menu"
              role="menu"
              aria-orientation="vertical"
              aria-labelledby="chapters-button"
            >
              <div class="py-0" role="none">
                <a
                  href="/chapters/denmark"
                  class="flex items-center gap-3 px-4 py-2 text-lg text-gray-700 hover:bg-blue-50 hover:text-gray-900"
                  role="menuitem"
                >
                  <img src="/flags/190-denmark.svg" alt="" class="h-5 w-5" />
                  <span>Denmark</span>
                </a>
                <a
                  href="/chapters/faroe-islands"
                  class="flex items-center gap-3 px-4 py-2 text-lg text-gray-700 hover:bg-blue-50 hover:text-gray-900"
                  role="menuitem"
                >
                  <img
                    src="/flags/115-faroe islands.svg"
                    alt=""
                    class="h-5 w-5"
                  />
                  <span>Faroe Islands</span>
                </a>
                <a
                  href="/chapters/finland"
                  class="flex items-center gap-3 px-4 py-2 text-lg text-gray-700 hover:bg-blue-50 hover:text-gray-900"
                  role="menuitem"
                >
                  <img src="/flags/210-finland.svg" alt="" class="h-5 w-5" />
                  <span>Finland</span>
                </a>
                <a
                  href="/chapters/greenland"
                  class="flex items-center gap-3 px-4 py-2 text-lg text-gray-700 hover:bg-blue-50 hover:text-gray-900"
                  role="menuitem"
                >
                  <img src="/flags/078-greenland.svg" alt="" class="h-5 w-5" />
                  <span>Greenland</span>
                </a>
                <a
                  href="/chapters/iceland"
                  class="flex items-center gap-3 px-4 py-2 text-lg text-gray-700 hover:bg-blue-50 hover:text-gray-900"
                  role="menuitem"
                >
                  <img src="/flags/221-iceland.svg" alt="" class="h-5 w-5" />
                  <span>Iceland</span>
                </a>
                <a
                  href="/chapters/norway"
                  class="flex items-center gap-3 px-4 py-2 text-lg text-gray-700 hover:bg-blue-50 hover:text-gray-900"
                  role="menuitem"
                >
                  <img src="/flags/204-norway.svg" alt="" class="h-5 w-5" />
                  <span>Norway</span>
                </a>
                <a
                  href="/chapters/sweden"
                  class="flex items-center gap-3 px-4 py-2 text-lg text-gray-700 hover:bg-blue-50 hover:text-gray-900"
                  role="menuitem"
                >
                  <img src="/flags/189-sweden.svg" alt="" class="h-5 w-5" />
                  <span>Sweden</span>
                </a>
              </div>
            </div>
          </div>
          <a
            href="/guides-resources"
            class="rounded-md px-3 py-2 text-lg font-medium text-gray-700 transition-colors hover:bg-blue-50 hover:text-gray-900"
          >
            Guides & Resources
          </a>
          <a
            href="/news"
            class="rounded-md px-3 py-2 text-lg font-medium text-gray-700 transition-colors hover:bg-blue-50 hover:text-gray-900"
          >
            News & Events
          </a>
          <a
            href="/faq"
            class="rounded-md px-3 py-2 text-lg font-medium text-gray-700 transition-colors hover:bg-blue-50 hover:text-gray-900"
          >
            FAQs
          </a>
          <a
            href="/contact"
            class="rounded-md px-3 py-2 text-lg font-medium text-gray-700 transition-colors hover:bg-blue-50 hover:text-gray-900"
          >
            Contact
          </a>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="hidden items-center space-x-4 xl:flex">
        <a
          href="/donate"
          class="rounded-md border-1 border-gray-300 px-4 py-2 text-lg font-medium text-gray-700 transition-colors hover:bg-gray-50"
        >
          Donate
        </a>
        <a
          href="/membership"
          class="rounded-md border-1 border-blue-900 bg-blue-900 px-4 py-2 text-lg font-medium text-white transition-colors hover:bg-blue-800"
        >
          Join FiNAN
        </a>
      </div>

      <!-- Mobile CTA and menu button -->
      <div class="flex items-center space-x-3 xl:hidden">
        <a
          href="/membership"
          class="text-md flex h-10 items-center rounded-md bg-blue-900 px-4 font-medium text-white transition-colors hover:bg-blue-800"
        >
          Join FiNAN
        </a>
        <button
          id="mobile-menu-button"
          type="button"
          class="rounded bg-gray-200 p-2 text-gray-900 hover:bg-gray-500 focus:ring-2 focus:ring-gray-500 focus:outline-none"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <span class="sr-only">Open main menu</span>
          <!-- Hamburger icon -->
          <svg
            id="hamburger-icon"
            class="block h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <!-- X icon (hidden by default) -->
          <svg
            id="close-icon"
            class="hidden h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div class="hidden xl:hidden" id="mobile-menu">
      <div class="mt-2 space-y-1 border-t border-gray-200 pt-2 pb-3">
        <a
          href="/about"
          class="block py-2 text-lg font-medium text-gray-700 hover:text-gray-900"
        >
          About
        </a>
        <!-- Mobile Chapters Dropdown -->
        <div class="block">
          <button
            type="button"
            class="flex w-full items-center justify-between py-2 text-left text-lg font-medium text-gray-700 hover:text-gray-900"
            id="mobile-chapters-button"
            aria-expanded="false"
          >
            Chapters
            <svg
              class="h-4 w-4 transform transition-transform duration-200"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              id="mobile-chapters-icon"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="hidden space-y-1 pl-4" id="mobile-chapters-menu">
            <a
              href="/chapters/denmark"
              class="flex items-center gap-3 py-2 text-lg text-gray-600 hover:text-gray-900"
            >
              <img src="/flags/190-denmark.svg" alt="" class="h-5 w-5" />
              <span>Denmark</span>
            </a>
            <a
              href="/chapters/faroe-islands"
              class="flex items-center gap-3 py-2 text-lg text-gray-600 hover:text-gray-900"
            >
              <img src="/flags/115-faroe islands.svg" alt="" class="h-5 w-5" />
              <span>Faroe Islands</span>
            </a>
            <a
              href="/chapters/finland"
              class="flex items-center gap-3 py-2 text-lg text-gray-600 hover:text-gray-900"
            >
              <img src="/flags/210-finland.svg" alt="" class="h-5 w-5" />
              <span>Finland</span>
            </a>
            <a
              href="/chapters/greenland"
              class="flex items-center gap-3 py-2 text-lg text-gray-600 hover:text-gray-900"
            >
              <img src="/flags/078-greenland.svg" alt="" class="h-5 w-5" />
              <span>Greenland</span>
            </a>
            <a
              href="/chapters/iceland"
              class="flex items-center gap-3 py-2 text-lg text-gray-600 hover:text-gray-900"
            >
              <img src="/flags/221-iceland.svg" alt="" class="h-5 w-5" />
              <span>Iceland</span>
            </a>
            <a
              href="/chapters/norway"
              class="flex items-center gap-3 py-2 text-lg text-gray-600 hover:text-gray-900"
            >
              <img src="/flags/204-norway.svg" alt="" class="h-5 w-5" />
              <span>Norway</span>
            </a>
            <a
              href="/chapters/sweden"
              class="flex items-center gap-3 py-2 text-lg text-gray-600 hover:text-gray-900"
            >
              <img src="/flags/189-sweden.svg" alt="" class="h-5 w-5" />
              <span>Sweden</span>
            </a>
          </div>
        </div>
        <a
          href="/guides-resources"
          class="block py-2 text-lg font-medium text-gray-700 hover:text-gray-900"
        >
          Guides & Resources
        </a>
        <a
          href="/news"
          class="block py-2 text-lg font-medium text-gray-700 hover:text-gray-900"
        >
          News & Events
        </a>
        <a
          href="/faq"
          class="block py-2 text-lg font-medium text-gray-700 hover:text-gray-900"
        >
          FAQs
        </a>
        <a
          href="/contact"
          class="block py-2 text-lg font-medium text-gray-700 hover:text-gray-900"
        >
          Contact
        </a>
        <div class="pt-4 pb-3">
          <div class="flex flex-col space-y-2">
            <a
              href="/donate"
              class="rounded-md border border-gray-300 px-4 py-2 text-center text-lg font-medium text-gray-700 transition-colors hover:bg-gray-50"
            >
              Donate
            </a>
            <a
              href="/membership"
              class="rounded-md border border-blue-900 bg-blue-900 px-4 py-2 text-center text-lg font-medium text-white transition-colors hover:bg-blue-800"
            >
              Join FiNAN
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>

<script is:inline src="/js/navbar.js" defer></script>
