---
// BannerTriennialGathering.astro - Triennial Gathering notification banner
import { Image } from 'astro:assets';
import bannerImage from '../assets/images/events/banner-triennial-gathering-2026.jpg';
---

<section class="relative overflow-hidden" id="banner-triennial-gathering">
  <Image
    src={bannerImage}
    alt="Northern Lights over Reykjavik, Iceland"
    class="absolute inset-0 h-full w-full object-cover object-top"
    loading="eager"
    format="webp"
    quality={65}
    width={1920}
    height={1080}
  />
  <div class="absolute inset-0 bg-blue-900/70"></div>
  <div
    class="relative mx-auto flex max-w-5xl flex-col items-center gap-4 px-4 py-4 text-center text-white"
  >
    <p class="text-base font-medium md:text-lg">
      Registration for the FiNAN Triennial Gathering 2026 is now open.
      <span class="block">
        Join us in Reykjavik, Iceland on March 30 – April 1, 2026.
        <a
          href="/triennial-gathering-2026"
          class="ml-2 font-semibold text-white underline underline-offset-4 transition-colors duration-200 hover:text-gray-100"
        >
          More info →
        </a>
      </span>
    </p>
  </div>
</section>
