---
// PageHeader.astro - Reusable page header component
import { Image } from 'astro:assets';

export interface Props {
  title: string;
  description?: string;
  backgroundImage?: ImageMetadata;
  backgroundAlt?: string;
  className?: string;
}

const {
  title,
  description,
  backgroundImage,
  backgroundAlt = '',
  className = '',
} = Astro.props;
---

<section class={`relative flex items-center py-20 md:py-32 ${className}`}>
  {
    backgroundImage && (
      <Image
        src={backgroundImage}
        alt={backgroundAlt}
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
        format="webp"
        width={1920}
        height={1080}
      />
    )
  }

  <!-- Gray overlay -->
  <div class="absolute inset-0 bg-gray-900/90"></div>

  <!-- Content -->
  <div
    class="relative z-10 mx-auto w-full max-w-screen-xl px-4 text-white sm:px-6"
  >
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="mb-6 text-5xl leading-tight font-bold lg:text-6xl">
        {title}
      </h1>

      {
        description && (
          <p class="mx-auto max-w-3xl text-lg leading-relaxed text-gray-200 md:text-xl">
            {description}
          </p>
        )
      }
    </div>
  </div>
</section>
