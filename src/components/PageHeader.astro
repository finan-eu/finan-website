---
// PageHeader.astro - Reusable page header component
import { Image } from 'astro:assets';

export interface Props {
  title: string;
  description?: string;
  contactEmail?: string;
  backgroundImage?: ImageMetadata;
  backgroundAlt?: string;
  className?: string;
}

const {
  title,
  description,
  contactEmail,
  backgroundImage,
  backgroundAlt = '',
  className = '',
} = Astro.props;
---

<section
  class={`relative flex items-center overflow-hidden py-20 md:py-40 ${className}`}
  transition:animate="none"
>
  {
    backgroundImage && (
      <Image
        src={backgroundImage}
        alt={backgroundAlt}
        class="absolute inset-0 h-full w-full object-cover object-top"
        loading="eager"
        format="webp"
        quality={65}
        width={1920}
        height={1080}
      />
    )
  }

  <!-- Gray overlay -->
  <div class="absolute inset-0 bg-gray-900/70"></div>

  <!-- Content -->
  <div class="relative z-10 mx-auto w-full max-w-7xl px-4 text-white sm:px-6">
    <div
      class="motion-stagger-children mx-auto max-w-4xl text-center"
      data-motion-stagger="0.16"
      data-motion-margin="0px"
      transition:animate="none"
    >
      <h1 class="mb-6 text-4xl leading-tight font-bold sm:text-5xl lg:text-6xl">
        {title}
      </h1>

      {
        description && (
          <p class="mx-auto max-w-4xl text-lg leading-relaxed text-gray-200 md:text-xl">
            {description}
          </p>
        )
      }

      {
        contactEmail && (
          <p class="mt-4 text-base text-gray-300 md:text-lg">
            Contact us:{' '}
            <a
              href={`mailto:${contactEmail}`}
              class="font-medium text-white underline hover:text-gray-100"
            >
              {contactEmail}
            </a>
          </p>
        )
      }
    </div>
  </div>
</section>
