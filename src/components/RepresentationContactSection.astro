---
// Regional representation contact information
const regions = [
  {
    title: 'Kingdom of Denmark',
    flags: [
      { src: '/assets/flags/flag_denmark.svg', alt: 'Denmark flag' },
      {
        src: '/assets/flags/flag_faroe_islands.svg',
        alt: 'Faroe Islands flag',
      },
      { src: '/assets/flags/flag_greenland.svg', alt: 'Greenland flag' },
    ],
    description:
      'Connect with Filipino nurses across Denmark, Faroe Islands, and Greenland. Get support with licensing, cultural integration, and professional development opportunities.',
    contacts: [
      { label: 'Denmark', email: 'denmark@finan.eu.com' },
      { label: 'Faroe Islands', email: 'faroeislands@finan.eu.com' },
      { label: 'Greenland', email: 'greenland@finan.eu.com' },
    ],
  },
  {
    title: 'Finland & Åland',
    flags: [
      { src: '/assets/flags/flag_finland.svg', alt: 'Finland flag' },
      {
        src: '/assets/flags/flag_aland_islands.svg',
        alt: 'Åland Islands flag',
      },
    ],
    description:
      'Join our vibrant community of Filipino nurses in Finland and Åland. Access resources for Valvira registration, language support, and networking events.',
    contacts: [{ label: '', email: 'finland@finan.eu.com' }],
  },
  {
    title: 'Iceland',
    flags: [{ src: '/assets/flags/flag_iceland.svg', alt: 'Iceland flag' }],
    description:
      'Connect with Filipino nurses working in Iceland. Get guidance on healthcare licensing, relocation support, and community integration in the land of fire and ice.',
    contacts: [{ label: '', email: 'iceland@finan.eu.com' }],
  },
  {
    title: 'Norway',
    flags: [{ src: '/assets/flags/flag_norway.svg', alt: 'Norway flag' }],
    description:
      "Reach out to our Norwegian chapter for information on nurse authorization, career opportunities, and community events across Norway's healthcare sector.",
    contacts: [{ label: '', email: 'norway@finan.eu.com' }],
  },
  {
    title: 'Sweden',
    flags: [{ src: '/assets/flags/flag_sweden.svg', alt: 'Sweden flag' }],
    description:
      'Connect with Filipino nurses in Sweden. Get assistance with Socialstyrelsen registration, Swedish language resources, and professional networking opportunities.',
    contacts: [{ label: '', email: 'sweden@finan.eu.com' }],
  },
];
---

<section class="bg-white pb-16">
  <div class="mx-auto max-w-4xl px-4 sm:px-6">
    <div class="grid gap-8 md:grid-cols-2">
      {
        regions.map((region) => (
          <div class="rounded-lg bg-white p-6 shadow-sm">
            {/* Flag icons */}
            <div class="mb-4 flex gap-2">
              {region.flags.map((flag) => (
                <img
                  src={flag.src}
                  alt={flag.alt}
                  class="h-10 w-auto object-contain"
                />
              ))}
            </div>

            {/* Title */}
            <h3 class="mb-3 text-2xl font-bold text-gray-900">
              {region.title}
            </h3>

            {/* Description */}
            <p class="mb-4 text-gray-700">{region.description}</p>

            {/* Contact emails */}
            <div class="space-y-1">
              {region.contacts.map((contact) => (
                <p class="text-gray-900">
                  {contact.label && (
                    <span class="font-medium">{contact.label}: </span>
                  )}
                  <a
                    href={`mailto:${contact.email}`}
                    class="text-blue-600 underline hover:text-blue-800"
                  >
                    {contact.email}
                  </a>
                </p>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
