---
// Blog.astro - News & Events section showcasing FiNAN's latest updates
import { getBlogPosts } from '../lib/ghost';

// Fetch latest 6 blog posts from Ghost CMS
const posts = await getBlogPosts(6);

// Helper function to format date
function formatDate(dateString: string) {
  return new Date(dateString).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

// Helper function to get primary tag
function getPrimaryTag(post: any) {
  return post.tags && post.tags.length > 0 ? post.tags[0].name : 'News';
}
---

<!-- News & Events Section -->
<section class="bg-gray-50 py-16 md:py-24">
  <div class="mx-auto max-w-screen-xl px-6">
    <!-- Header -->
    <div class="mb-16 text-center">
      <h2 class="mb-6 text-3xl font-bold text-gray-900 md:text-4xl">
        News & Events
      </h2>
      <p class="mx-auto max-w-4xl text-lg leading-relaxed text-gray-700">
        Stay up to date with FiNAN's latest news, policy updates, and community
        events. Join us in our mission to support and empower Filipino nurses
        across the Nordic region.
      </p>
    </div>

    <!-- Blog Grid -->
    <div class="mb-12 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        posts.map((post) => (
          <article class="overflow-hidden rounded-lg border border-gray-200 bg-white transition-shadow duration-300 hover:shadow-lg">
            <div class="aspect-[3/2] bg-gray-200">
              <img
                src={post.feature_image || '/images/image_thumbnail.svg'}
                alt={post.title}
                class="h-full w-full object-cover"
              />
            </div>
            <div class="p-6">
              <div class="mb-3 flex items-center gap-2">
                <span class="rounded bg-gray-100 px-2 py-1 text-sm font-medium text-gray-900">
                  {getPrimaryTag(post)}
                </span>
                <span class="text-sm text-gray-600">
                  {formatDate(post.published_at)}
                </span>
              </div>
              <h3 class="mb-3 text-xl font-bold text-gray-900">{post.title}</h3>
              <p class="mb-4 leading-relaxed text-gray-700">{post.excerpt}</p>
              <a
                href={post.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center font-medium text-gray-900 transition-colors hover:text-gray-700"
              >
                Read More
                <svg
                  class="ml-1 h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </a>
            </div>
          </article>
        ))
      }
    </div>

    <!-- View All Button -->
    <div class="text-center">
      <a
        href="https://puls.finan.eu.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded-lg border-2 border-blue-900 px-8 py-3 font-medium text-blue-900 transition-all duration-300 hover:bg-blue-900 hover:text-white"
      >
        View All News & Events
      </a>
    </div>
  </div>
</section>
