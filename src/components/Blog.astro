---
// Blog.astro - News & Events section showcasing FiNAN's latest updates
---

<!-- News & Events Section -->
<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-screen-xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
        News & Events
      </h2>
      <p class="text-lg text-gray-700 max-w-4xl mx-auto leading-relaxed">
        Stay up to date with FiNAN's latest news, policy updates, and community
        events. Join us in our mission to support and empower Filipino nurses
        across the Nordic region.
      </p>
    </div>

    <!-- Blog Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
      <!-- Blog Post 1 -->
      <article
        class="bg-white border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition-shadow duration-300"
      >
        <div class="aspect-[3/2] bg-gray-200">
          <img
            src="/images/image_thumbnail.svg"
            alt="International Nursing Conference 2025 in Switzerland"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="p-6">
          <div class="flex items-center gap-2 mb-3">
            <span
              class="text-sm font-medium text-gray-900 bg-gray-100 px-2 py-1 rounded"
              >Event</span
            >
            <span class="text-sm text-gray-600">April 1, 2025</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">
            International Nursing Conference 2025 in Switzerland
          </h3>
          <p class="text-gray-700 mb-4 leading-relaxed">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse
            varius enim in eros.
          </p>
          <a
            href="#"
            class="inline-flex items-center text-gray-900 font-medium hover:text-gray-700 transition-colors"
          >
            Learn More
            <svg
              class="w-4 h-4 ml-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </article>

      <!-- Blog Post 2 -->
