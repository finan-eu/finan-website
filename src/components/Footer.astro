---
import { socialMediaLinks } from '../data/socialMediaConfig';

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-gray-200 bg-white pt-12 pb-8 md:pt-20">
  <div class="mx-auto max-w-screen-xl px-6">
    <!-- Top section with logo and social media -->
    <div class="mb-20 grid grid-cols-1 gap-20 lg:grid-cols-2">
      <div class="flex flex-col items-start gap-8">
        <img
          src="/finan-logo.svg"
          alt="FINAN"
          class="h-20 w-auto xl:h-24"
          loading="eager"
        />
        <p class="max-w-md text-base leading-6 font-normal text-gray-900">
          FiNAN is a non-profit organization that connects, supports, and
          advocates for Filipino nurses across the Nordic region.
        </p>
        <div class="flex flex-col">
          <h3 class="mb-6 text-base font-semibold text-gray-900">Follow Us</h3>
          <ul class="m-0 flex list-none flex-col gap-4 p-0">
            {
              socialMediaLinks.map((social) => (
                <li>
                  <a
                    href={social.url}
                    class="flex items-center gap-3 text-base font-normal text-gray-500 no-underline transition-colors hover:text-gray-900"
                  >
                    <img
                      src={social.icon}
                      alt={social.alt}
                      class="h-5 w-5 opacity-70 transition-opacity hover:opacity-100"
                    />
                    <span>{social.name}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Navigation columns -->
      <div
        class="grid grid-cols-1 gap-12 justify-self-end md:grid-cols-2 md:gap-12"
      >
        <div class="flex flex-col items-start">
          <h3 class="mb-6 text-base font-semibold text-gray-900">
            Representation
          </h3>
          <ul class="m-0 flex list-none flex-col gap-4 p-0">
            <li>
              <a
                href="/representation/kingdom-denmark"
                class="text-base font-normal text-gray-500 no-underline transition-colors hover:text-gray-900"
                >Kingdom of Denmark</a
              >
            </li>
            <li>
              <a
                href="/representation/faroe-islands"
                class="text-base font-normal text-gray-500 no-underline transition-colors hover:text-gray-900"
                >Faroe Islands</a
              >
            </li>
            <li>
              <a
                href="/representation/finland"
                class="text-base font-normal text-gray-500 no-underline transition-colors hover:text-gray-900"
                >Finland</a
              >
            </li>
            <li>
              <a
                href="/representation/greenland"
                class="text-base font-normal text-gray-500 no-underline transition-colors hover:text-gray-900"
                >Greenland</a
              >
            </li>
            <li>
              <a
                href="/representation/iceland"
                class="text-base font-normal text-gray-500 no-underline transition-colors hover:text-gray-900"
                >Iceland</a
              >
            </li>
            <li>
              <a
                href="/representation/norway"
                class="text-base font-normal text-gray-500 no-underline transition-colors hover:text-gray-900"
                >Norway</a
              >
            </li>
            <li>
              <a
                href="/representation/sweden"
                class="text-base font-normal text-gray-500 no-underline transition-colors hover:text-gray-900"
                >Sweden</a
              >
            </li>
          </ul>
        </div>

        <div class="flex flex-col">
          <h3 class="mb-6 text-base font-semibold text-gray-900">
            Quick Links
          </h3>
          <ul class="m-0 flex list-none flex-col gap-4 p-0">
            <li>
              <a
                href="#"
                class="text-base font-normal text-gray-500 no-underline transition-colors hover:text-gray-900"
                >FiNAN Puls (Members Portal)</a
              >
            </li>
            <li>
              <a
                href="https://app.fastmail.com/"
                class="text-base font-normal text-gray-500 no-underline transition-colors hover:text-gray-900"
                >Staff Email</a
              >
            </li>
            <li>
              <a
                href="https://puls.finan.eu.com/"
                class="text-base font-normal text-gray-500 no-underline transition-colors hover:text-gray-900"
                >News & Events</a
              >
            </li>
            <li>
              <a
                href="https://puls.finan.eu.com/tag/guides-resources/"
                class="text-base font-normal text-gray-500 no-underline transition-colors hover:text-gray-900"
                >Guides & Resources</a
              >
            </li>
            <li>
              <a
                href="https://puls.finan.eu.com/triennial-gathering/"
                class="text-base font-normal text-gray-500 no-underline transition-colors hover:text-gray-900"
                >Triennial Gathering</a
              >
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom section with copyright and legal links -->
    <div class="border-t border-gray-200 pt-8">
      <div class="flex flex-col items-center justify-between gap-4 md:flex-row">
        <p class="m-0 text-base font-normal text-gray-500">
          © {currentYear} FiNAN. All rights reserved.
        </p>
        <div>
          <a
            href="/terms-agreement"
            class="text-base font-normal text-gray-500 no-underline transition-colors hover:text-gray-900"
            >Terms and Agreement</a
          >
        </div>
      </div>
    </div>
  </div>
</footer>
