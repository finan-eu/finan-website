---
import { Image } from 'astro:assets';
import finanLogo from '../assets/finan-logo.svg';

const currentYear = new Date().getFullYear();
---

<footer class="bg-white pt-20 pb-8 border-t border-gray-200">
  <div class="max-w-screen-xl mx-auto px-6">
    <!-- Top section with logo and newsletter -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 mb-20">
      <div class="flex flex-col gap-8">
        <Image
          src={finanLogo}
          alt="FINAN"
          class="w-30 h-auto"
          width={120}
          height={64}
        />
        <div class="max-w-md">
          <p class="text-base font-normal leading-6 text-gray-900 mb-6">
            Join our newsletter to stay up to date on features and releases.
          </p>
          <form class="flex flex-col sm:flex-row gap-3 mb-4">
            <input
              type="email"
              placeholder="Enter your email"
              class="flex-1 px-4 py-3 text-base border border-gray-300 rounded-lg bg-white text-gray-900 placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
              required
            />
            <button
              type="submit"
              class="px-6 py-3 text-base font-medium bg-gray-900 text-white border-0 rounded-lg cursor-pointer hover:bg-gray-800 transition-colors"
              >Subscribe</button
            >
          </form>
          <p class="text-sm leading-5 text-gray-500 m-0">
            By subscribing you agree to with our <a
              href="/privacy-policy"
              class="text-gray-900 underline hover:text-blue-500"
              >Privacy Policy</a
            > and provide consent to receive updates from our company.
          </p>
        </div>
      </div>

      <!-- Navigation columns -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="flex flex-col">
          <h3 class="text-base font-semibold text-gray-900 mb-6">Services</h3>
          <ul class="list-none p-0 m-0 flex flex-col gap-4">
            <li>
              <a
                href="#"
                class="text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
                >Services One</a>
            </li>
            <li>
              <a
                href="#"
                class="text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
                >Services Two</a>
            </li>
            <li>
              <a
                href="#"
                class="text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
                >Services Three</a>
            </li>
            <li>
              <a
                href="#"
                class="text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
                >Services Four</a>
            </li>
            <li>
              <a
                href="#"
                class="text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
                >Services Five</a>
            </li>
          </ul>
        </div>

        <div class="flex flex-col">
          <h3 class="text-base font-semibold text-gray-900 mb-6">
            Nordic Chapters
          </h3>
          <ul class="list-none p-0 m-0 flex flex-col gap-4">
            <li>
              <a
                href="#"
                class="text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
                >Denmark</a>
            </li>
            <li>
              <a
                href="#"
                class="text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
                >Faroe Islands</a>
            </li>
            <li>
              <a
                href="#"
                class="text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
                >Finland</a>
            </li>
            <li>
              <a
                href="#"
                class="text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
                >Greenland</a>
            </li>
            <li>
              <a
                href="#"
                class="text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
                >Iceland</a>
            </li>
            <li>
              <a
                href="#"
                class="text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
                >Norway</a>
            </li>
            <li>
              <a
                href="#"
                class="text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
                >Sweden</a>
            </li>
          </ul>
        </div>

        <div class="flex flex-col">
          <h3 class="text-base font-semibold text-gray-900 mb-6">Follow Us</h3>
          <ul class="list-none p-0 m-0 flex flex-col gap-4">
            <li>
              <a
                href="#"
                class="flex items-center gap-3 text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
              >
                <img
                  src="/icons/socmed/facebook.svg"
                  alt="Facebook"
                  class="w-5 h-5 opacity-70 hover:opacity-100 transition-opacity"
                />
                <span>Facebook</span>
              </a>
            </li>
            <li>
              <a
                href="#"
                class="flex items-center gap-3 text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
              >
                <img
                  src="/icons/socmed/instagram.svg"
                  alt="Instagram"
                  class="w-5 h-5 opacity-70 hover:opacity-100 transition-opacity"
                />
                <span>Instagram</span>
              </a>
            </li>
            <li>
              <a
                href="#"
                class="flex items-center gap-3 text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
              >
                <img
                  src="/icons/socmed/x-twitter.svg"
                  alt="X"
                  class="w-5 h-5 opacity-70 hover:opacity-100 transition-opacity"
                />
                <span>X</span>
              </a>
            </li>
            <li>
              <a
                href="#"
                class="flex items-center gap-3 text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
              >
                <img
                  src="/icons/socmed/linkedin.svg"
                  alt="LinkedIn"
                  class="w-5 h-5 opacity-70 hover:opacity-100 transition-opacity"
                />
                <span>LinkedIn</span>
              </a>
            </li>
            <li>
              <a
                href="#"
                class="flex items-center gap-3 text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
              >
                <img
                  src="/icons/socmed/youtube.svg"
                  alt="Youtube"
                  class="w-5 h-5 opacity-70 hover:opacity-100 transition-opacity"
                />
                <span>Youtube</span>
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom section with copyright and legal links -->
    <div class="border-t border-gray-200 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-base font-normal text-gray-500 m-0">
          © {currentYear} FiNAN. All rights reserved.
        </p>
        <div class="flex flex-col md:flex-row gap-4 md:gap-8">
          <a
            href="/privacy-policy"
            class="text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
            >Privacy Policy</a
          >
          <a
            href="/terms-of-service"
            class="text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
            >Terms of Service</a
          >
          <a
            href="/cookies-settings"
            class="text-base font-normal text-gray-500 no-underline hover:text-gray-900 transition-colors"
            >Cookies Settings</a
          >
        </div>
      </div>
    </div>
  </div>
</footer>
