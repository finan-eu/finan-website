---
// MembershipForm.astro - Membership application form component
---

<div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
  <form
    name="membershipApplication"
    class="space-y-8"
    aria-label="Membership Application Form"
    novalidate
  >
    <!-- Name Fields -->
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <div>
        <!-- First Name -->
        <label
          for="firstName"
          class="block text-base font-semibold text-gray-900"
        >
          First name<span class="text-red-600">*</span>
        </label>
        <input
          type="text"
          id="firstName"
          name="firstName"
          autocomplete="given-name"
          placeholder="Enter your first name"
          required
          aria-required="true"
          aria-describedby="firstName-error"
          class="mt-2 block w-full rounded-none border border-gray-900 px-4 py-3 text-base focus:border-blue-800 focus:ring-1 focus:ring-blue-800 focus:outline-none"
        />
        <span id="firstName-error" class="sr-only" role="alert"></span>
      </div>

      <div>
        <!-- Last Name -->
        <label
          for="lastName"
          class="block text-base font-semibold text-gray-900"
        >
          Last name<span class="text-red-600">*</span>
        </label>
        <input
          type="text"
          id="lastName"
          name="lastName"
          autocomplete="family-name"
          placeholder="Enter your last name"
          required
          aria-required="true"
          aria-describedby="lastName-error"
          class="mt-2 block w-full rounded-none border border-gray-900 px-4 py-3 text-base focus:border-blue-800 focus:ring-1 focus:ring-blue-800 focus:outline-none"
        />
        <span id="lastName-error" class="sr-only" role="alert"></span>
      </div>
    </div>

    <!-- Email Field -->
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <div>
        <label for="email" class="block text-base font-semibold text-gray-900">
          Email<span class="text-red-600">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          autocomplete="email"
          placeholder="your.email@example.com"
          required
          aria-required="true"
          aria-describedby="email-error"
          class="mt-2 block w-full rounded-none border border-gray-900 px-4 py-3 text-base focus:border-blue-800 focus:ring-1 focus:ring-blue-800 focus:outline-none"
        />
        <span id="email-error" class="sr-only" role="alert"></span>
      </div>
    </div>

    <!-- Country of Residence -->
    <fieldset>
      <legend class="block text-base font-semibold text-gray-900">
        Country of Residence<span class="text-red-600">*</span>
      </legend>
      <div
        class="mt-4 grid grid-cols-1 gap-4 md:grid-cols-2"
        role="radiogroup"
        aria-required="true"
      >
        <div class="flex items-center">
          <input
            type="radio"
            id="residence-denmark"
            name="countryOfResidence"
            value="Denmark"
            required
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="residence-denmark" class="ml-3 text-base text-gray-900">
            Denmark
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="radio"
            id="residence-iceland"
            name="countryOfResidence"
            value="Iceland"
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="residence-iceland" class="ml-3 text-base text-gray-900">
            Iceland
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="radio"
            id="residence-faroe"
            name="countryOfResidence"
            value="Faroe Islands"
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="residence-faroe" class="ml-3 text-base text-gray-900">
            Faroe Islands
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="radio"
            id="residence-norway"
            name="countryOfResidence"
            value="Norway"
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="residence-norway" class="ml-3 text-base text-gray-900">
            Norway
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="radio"
            id="residence-finland"
            name="countryOfResidence"
            value="Finland"
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="residence-finland" class="ml-3 text-base text-gray-900">
            Finland
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="radio"
            id="residence-sweden"
            name="countryOfResidence"
            value="Sweden"
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="residence-sweden" class="ml-3 text-base text-gray-900">
            Sweden
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="radio"
            id="residence-greenland"
            name="countryOfResidence"
            value="Greenland"
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="residence-greenland" class="ml-3 text-base text-gray-900">
            Greenland
          </label>
        </div>
      </div>
    </fieldset>

    <!-- Registered Nurse in Philippines -->
    <fieldset class="md:max-w-xl">
      <legend class="block text-base font-semibold text-gray-900">
        Are you a Registered Nurse in the Philippines? All Filipinos who studied
        and graduated nursing in the Nordic Region are also welcome.<span
          class="text-red-600">*</span
        >
      </legend>
      <div
        class="mt-4 space-y-4"
        role="radiogroup"
        aria-required="true"
        aria-describedby="registered-nurse-description"
      >
        <span id="registered-nurse-description" class="sr-only">
          Select whether you are a registered nurse in the Philippines or
          studied nursing in the Nordic Region
        </span>
        <div class="flex items-center">
          <input
            type="radio"
            id="registered-yes"
            name="registeredNursePhilippines"
            value="Yes"
            required
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="registered-yes" class="ml-3 text-base text-gray-900">
            Yes
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="radio"
            id="registered-no"
            name="registeredNursePhilippines"
            value="No"
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="registered-no" class="ml-3 text-base text-gray-900">
            No
          </label>
        </div>
      </div>
    </fieldset>

    <!-- Philippines License Number -->
    <div
      id="philippinesLicenseField"
      class="hidden grid-cols-1 gap-6 md:grid-cols-2"
      aria-live="polite"
    >
      <div>
        <label
          for="philippinesLicenseNumber"
          class="block text-base font-semibold text-gray-900"
        >
          Philippine License Number <span class="text-red-600">*</span>
        </label>
        <input
          type="text"
          id="philippinesLicenseNumber"
          name="philippinesLicenseNumber"
          placeholder="Enter your PRC license number"
          aria-describedby="philippinesLicenseNumber-error"
          class="mt-2 block w-full rounded-none border border-gray-900 px-4 py-3 text-base focus:border-blue-800 focus:ring-1 focus:ring-blue-800 focus:outline-none"
        />
        <span id="philippinesLicenseNumber-error" class="sr-only" role="alert"
        ></span>
      </div>
    </div>

    <!-- Current Nursing Status -->
    <fieldset>
      <legend class="block text-base font-semibold text-gray-900">
        What is your current nursing status in the Nordic region?<span
          class="text-red-600">*</span
        >
      </legend>
      <div class="mt-4 space-y-4" role="radiogroup" aria-required="true">
        <div class="flex items-center">
          <input
            type="radio"
            id="status-registered"
            name="nursingStatus"
            value="Registered Nurse"
            required
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="status-registered" class="ml-3 text-base text-gray-900">
            Registered Nurse
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="radio"
            id="status-licensed"
            name="nursingStatus"
            value="Licensed Practical Nurse"
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="status-licensed" class="ml-3 text-base text-gray-900">
            Licensed Practical Nurse
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="radio"
            id="status-assistant"
            name="nursingStatus"
            value="Nursing Assistant"
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="status-assistant" class="ml-3 text-base text-gray-900">
            Nursing Assistant
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="radio"
            id="status-studying"
            name="nursingStatus"
            value="Studying/Training"
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="status-studying" class="ml-3 text-base text-gray-900">
            Studying/Training
          </label>
        </div>
      </div>
    </fieldset>

    <!-- Nordic Country Working In -->
    <fieldset>
      <legend class="block text-base font-semibold text-gray-900">
        Which Nordic Country? <span class="text-red-600">*</span>
      </legend>
      <div
        class="mt-4 grid grid-cols-1 gap-4 md:grid-cols-2"
        role="radiogroup"
        aria-required="true"
      >
        <div class="flex items-center">
          <input
            type="radio"
            id="nordic-denmark"
            name="nordicCountry"
            value="Denmark"
            required
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="nordic-denmark" class="ml-3 text-base text-gray-900">
            Denmark
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="radio"
            id="nordic-iceland"
            name="nordicCountry"
            value="Iceland"
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="nordic-iceland" class="ml-3 text-base text-gray-900">
            Iceland
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="radio"
            id="nordic-faroe"
            name="nordicCountry"
            value="Faroe Islands"
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="nordic-faroe" class="ml-3 text-base text-gray-900">
            Faroe Islands
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="radio"
            id="nordic-norway"
            name="nordicCountry"
            value="Norway"
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="nordic-norway" class="ml-3 text-base text-gray-900">
            Norway
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="radio"
            id="nordic-finland"
            name="nordicCountry"
            value="Finland"
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="nordic-finland" class="ml-3 text-base text-gray-900">
            Finland
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="radio"
            id="nordic-sweden"
            name="nordicCountry"
            value="Sweden"
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="nordic-sweden" class="ml-3 text-base text-gray-900">
            Sweden
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="radio"
            id="nordic-greenland"
            name="nordicCountry"
            value="Greenland"
            class="h-5 w-5 border-gray-900 text-blue-800 focus:ring-blue-800"
          />
          <label for="nordic-greenland" class="ml-3 text-base text-gray-900">
            Greenland
          </label>
        </div>
      </div>
    </fieldset>

    <!-- Nordic License Number -->
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <div>
        <label
          for="nordicLicenseNumber"
          class="block text-base font-semibold text-gray-900"
        >
          License Number <span class="text-red-600">*</span>
        </label>
        <p id="nordicLicenseNumber-hint" class="mt-1 text-sm text-gray-600">
          If ongoing, type 000000 and update the membership director later
        </p>
        <input
          type="text"
          id="nordicLicenseNumber"
          name="nordicLicenseNumber"
          placeholder="Enter your license number or 000000 if ongoing"
          required
          aria-required="true"
          aria-describedby="nordicLicenseNumber-hint nordicLicenseNumber-error"
          class="mt-2 block w-full rounded-none border border-gray-900 px-4 py-3 text-base focus:border-blue-800 focus:ring-1 focus:ring-blue-800 focus:outline-none"
        />
        <span id="nordicLicenseNumber-error" class="sr-only" role="alert"
        ></span>
      </div>
    </div>

    <!-- Terms & Agreement -->
    <div class="border-t border-gray-200 pt-8">
      <fieldset>
        <legend class="block text-base font-semibold text-gray-900">
          Terms & Agreement<span class="text-red-600">*</span>
        </legend>
        <div class="space-y-4 pt-4 md:max-w-xl">
          <div class="flex items-start">
            <input
              type="checkbox"
              id="dataAgreement"
              name="dataAgreement"
              required
              aria-required="true"
              aria-describedby="dataAgreement-error"
              class="mt-1 h-6 min-h-6 w-6 min-w-6 shrink-0 rounded border-gray-900 text-blue-800 focus:ring-blue-800"
            />
            <label for="dataAgreement" class="ml-3 text-base text-gray-900">
              I am aware that my information will be stored in the FiNAN's data
              storage and shall only be used for data collection. All
              information gathered are protected under EU Directive.
            </label>
            <span id="dataAgreement-error" class="sr-only" role="alert"></span>
          </div>

          <p class="text-base text-gray-900">
            By submitting this form, you agree to the <a
              href="#"
              class="underline hover:text-gray-700"
              aria-label="FiNAN Terms and Privacy Policy (opens in new context)"
              >Terms and Privacy Policy</a
            > of FiNAN
          </p>
        </div>
      </fieldset>
    </div>

    <!-- Submit Button -->
    <div>
      <button
        type="submit"
        class="cursor-pointer rounded-lg bg-blue-900 px-8 py-3 text-base font-semibold text-white shadow-lg transition-all duration-200 hover:bg-blue-800 hover:shadow-xl focus:ring-2 focus:ring-blue-900 focus:ring-offset-2 focus:outline-none"
      >
        Submit form
      </button>
    </div>
  </form>
</div>

<script>
  // Handle Philippines License Number field visibility
  const registeredYes = document.getElementById(
    'registered-yes'
  ) as HTMLInputElement | null;
  const registeredNo = document.getElementById(
    'registered-no'
  ) as HTMLInputElement | null;
  const philippinesLicenseField = document.getElementById(
    'philippinesLicenseField'
  );
  const philippinesLicenseInput = document.getElementById(
    'philippinesLicenseNumber'
  ) as HTMLInputElement | null;

  function updatePhilippinesLicenseFieldVisibility() {
    if (registeredYes?.checked) {
      // Show field and make required
      philippinesLicenseField?.classList.remove('hidden');
      philippinesLicenseField?.classList.add('grid');
      philippinesLicenseInput?.setAttribute('required', 'required');
      philippinesLicenseInput?.setAttribute('aria-required', 'true');
      // Announce to screen readers
      philippinesLicenseInput?.focus();
    } else {
      // Hide field and remove required
      philippinesLicenseField?.classList.add('hidden');
      philippinesLicenseField?.classList.remove('grid');
      philippinesLicenseInput?.removeAttribute('required');
      philippinesLicenseInput?.removeAttribute('aria-required');
      // Clear the value when hidden
      if (philippinesLicenseInput) {
        philippinesLicenseInput.value = '';
      }
    }
  }

  // Add event listeners
  registeredYes?.addEventListener(
    'change',
    updatePhilippinesLicenseFieldVisibility
  );
  registeredNo?.addEventListener(
    'change',
    updatePhilippinesLicenseFieldVisibility
  );

  // Form validation with accessibility support
  const form = document.querySelector(
    'form[name="membershipApplication"]'
  ) as HTMLFormElement | null;

  if (form) {
    form.addEventListener('submit', function (e) {
      // Clear previous error messages
      const errorSpans = form.querySelectorAll('[role="alert"]');
      errorSpans.forEach((span) => {
        span.textContent = '';
      });

      // Let native HTML5 validation run first
      if (!form.checkValidity()) {
        e.preventDefault();

        // Find first invalid field and focus it
        const firstInvalid = form.querySelector(
          ':invalid'
        ) as HTMLInputElement | null;
        if (firstInvalid) {
          firstInvalid.focus();

          // Show error message for screen readers
          const errorId = firstInvalid.getAttribute('aria-describedby');
          if (errorId) {
            const errorIds = errorId.split(' ');
            const errorSpan = document.getElementById(
              errorIds[errorIds.length - 1]
            );
            if (errorSpan && errorSpan.hasAttribute('role')) {
              if (firstInvalid.validity.valueMissing) {
                errorSpan.textContent = 'This field is required';
              } else if (firstInvalid.validity.typeMismatch) {
                errorSpan.textContent = 'Please enter a valid value';
              } else {
                errorSpan.textContent = 'Please correct this field';
              }
            }
          }
        }
      }
    });

    // Real-time validation feedback
    const inputs = form.querySelectorAll(
      'input[required], input[type="email"]'
    );
    inputs.forEach((input) => {
      input.addEventListener('blur', function () {
        const htmlInput = input as HTMLInputElement;
        const errorId = htmlInput.getAttribute('aria-describedby');

        if (errorId) {
          const errorIds = errorId.split(' ');
          const errorSpan = document.getElementById(
            errorIds[errorIds.length - 1]
          );

          if (errorSpan && errorSpan.hasAttribute('role')) {
            if (!htmlInput.validity.valid) {
              if (htmlInput.validity.valueMissing) {
                errorSpan.textContent = 'This field is required';
              } else if (htmlInput.validity.typeMismatch) {
                errorSpan.textContent = 'Please enter a valid email address';
              } else {
                errorSpan.textContent = 'Please correct this field';
              }
            } else {
              errorSpan.textContent = '';
            }
          }
        }
      });

      // Clear error on input
      input.addEventListener('input', function () {
        const htmlInput = input as HTMLInputElement;
        const errorId = htmlInput.getAttribute('aria-describedby');

        if (errorId) {
          const errorIds = errorId.split(' ');
          const errorSpan = document.getElementById(
            errorIds[errorIds.length - 1]
          );

          if (errorSpan && errorSpan.hasAttribute('role')) {
            errorSpan.textContent = '';
          }
        }
      });
    });
  }
</script>
