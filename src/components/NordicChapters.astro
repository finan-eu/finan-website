---
// NordicChapters.astro - Nordic Chapters section showcasing FiNAN's regional presence
---

<!-- Nordic Chapters Section -->
<section class="py-16 md:py-24 bg-white">
  <div class="max-w-screen-xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
        Our Nordic Chapters
      </h2>
      <p class="text-lg text-gray-700 max-w-4xl mx-auto leading-relaxed">
        FiNAN unites Filipino nurses across the Nordic region through local
        chapters. Select your country to connect with your chapter, access local
        resources, and join community events.
      </p>
    </div>

    <!-- Country Links Grid -->
    <div class="flex flex-wrap justify-center gap-4 mb-8 max-w-3xl mx-auto">
      <!-- Denmark -->
      <a
        href="#"
        class="flex items-center gap-3 px-6 py-3 border-2 border-gray-300 rounded-lg hover:border-gray-900 hover:bg-gray-50 transition-all duration-300 min-w-[140px]"
      >
        <img
          src="/flags/190-denmark.svg"
          alt="Denmark flag"
          class="w-6 h-6"
        />
        <span class="font-medium text-gray-900">Denmark</span>
      </a>

      <!-- Faroe Islands -->
      <a
        href="#"
        class="flex items-center gap-3 px-6 py-3 border-2 border-gray-300 rounded-lg hover:border-gray-900 hover:bg-gray-50 transition-all duration-300 min-w-[140px]"
      >
