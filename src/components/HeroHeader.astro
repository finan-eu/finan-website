---
// HeroHeader.astro - Main hero section with FiNAN mission
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero-image.jpg';
import Navbar from './Navbar.astro';
import { heroConfig } from '../data/heroConfig';
---

<!-- Navigation -->
<Navbar />

<section class="relative min-h-screen-mobile flex items-center py-8">
  <Image
    src={heroImage}
    alt="Filipino nurses working together in Nordic healthcare"
    class="absolute inset-0 w-full h-full object-cover object-top"
    loading="eager"
    format="webp"
    width={1920}
    height={1080}
  />
  <!-- Gray overlay -->
  <div class="absolute inset-0 bg-gray-900/90"></div>

  <!-- Content -->
  <div
    class="relative z-10 max-w-screen-xl mx-auto px-4 sm:px-6 py-8 sm:py-12 md:py-16 text-white text-center w-full"
  >
    <h1
      class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 sm:mb-8 leading-tight"
      set:html={heroConfig.title.replace('Filipino Nurses in the Nordics', '<br /> Filipino Nurses in the Nordics')}
    ></h1>

    <p
      class="text-base sm:text-lg md:text-xl max-w-3xl mx-auto mb-8 sm:mb-12 px-2"
    >
      {heroConfig.description}
    </p>

    <p class="text-sm sm:text-base md:text-lg text-gray-200 mb-6 sm:mb-8 px-2">
      {heroConfig.contact.websiteText} <a
        href={heroConfig.contact.websiteUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="underline font-bold hover:text-white transition-colors"
        >{heroConfig.contact.websiteLabel}</a
      > {heroConfig.contact.emailText} <a
        href={`mailto:${heroConfig.contact.email}`}
        class="underline font-bold hover:text-white transition-colors"
        >{heroConfig.contact.email}</a
      >
    </p>

    <!-- Action Links -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href={heroConfig.buttons.primary.url}
        target="_blank"
        rel="noopener noreferrer"
        class="w-full sm:w-auto bg-white text-gray-900 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors shadow-lg inline-block text-center"
      >
        {heroConfig.buttons.primary.text}
      </a>
      <a
        href={heroConfig.buttons.secondary.url}
        target="_blank"
        rel="noopener noreferrer"
        class="w-full sm:w-auto border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-gray-900 transition-colors inline-block text-center"
      >
        {heroConfig.buttons.secondary.text}
      </a>
    </div>
  </div>
</section>
