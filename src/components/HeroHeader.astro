---
// HeroHeader.astro - Main hero section with FiNAN mission
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero-image.jpg';
import Navbar from './Navbar.astro';
import { heroConfig } from '../data/heroConfig';
---

<!-- Navigation -->
<Navbar />

<section class="relative flex items-center py-20 md:py-32">
  <Image
    src={heroImage}
    alt="Filipino nurses working together in Nordic healthcare"
    class="absolute inset-0 h-full w-full object-cover object-top"
    loading="eager"
    fetchpriority="high"
    decoding="async"
    format="webp"
    width={1920}
    height={1080}
  />
  <!-- Gray overlay -->
  <div class="absolute inset-0 bg-gray-900/90"></div>

  <!-- Content -->
  <div
    class="relative z-10 mx-auto w-full max-w-screen-xl px-4 py-8 text-center text-white sm:px-6 sm:py-12 md:py-16"
  >
    <h1
      class="mb-6 text-5xl font-bold leading-none sm:mb-8 lg:text-6xl"
      set:html={heroConfig.title.replace(
        'Filipino Nurses in the Nordics',
        '<br /> Filipino Nurses in the Nordics'
      )}
    />

    <p class="mx-auto mb-8 max-w-3xl text-base sm:mb-12 sm:text-lg md:text-xl">
      {heroConfig.description}
    </p>

    <p class="mb-6 text-base text-gray-200 sm:mb-8 sm:text-lg md:text-xl">
      {heroConfig.contact.websiteText}
      <a
        href={heroConfig.contact.websiteUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="font-bold underline transition-colors hover:text-white"
        >{heroConfig.contact.websiteLabel}</a
      >
      {heroConfig.contact.emailText}
      <a
        href={`mailto:${heroConfig.contact.email}`}
        class="font-bold underline transition-colors hover:text-white"
        >{heroConfig.contact.email}</a
      >
    </p>

    <!-- Action Links -->
    <div
      class="flex flex-col items-center justify-center gap-4 sm:flex-row"
    >
      <a
        href={heroConfig.buttons.primary.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block w-full rounded-lg border-2 border-white bg-white px-8 py-3 text-center font-semibold text-gray-900 shadow-lg transition-colors hover:bg-gray-100 sm:w-auto"
      >
        {heroConfig.buttons.primary.text}
      </a>
      <a
        href={heroConfig.buttons.secondary.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block w-full rounded-lg border-2 border-white px-8 py-3 text-center font-semibold text-white transition-colors hover:bg-white hover:text-gray-900 sm:w-auto"
      >
        {heroConfig.buttons.secondary.text}
      </a>
    </div>
  </div>
</section>
