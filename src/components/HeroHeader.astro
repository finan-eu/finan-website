---
// HeroHeader.astro - Main hero section with FiNAN mission
import { Image } from 'astro:assets';
import heroImage from '../assets/hero-image.jpg';
---

<section class="relative min-h-[80vh] md:h-screen flex items-center">
  <Image
    src={heroImage}
    alt="Filipino nurses working together in Nordic healthcare"
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
    format="webp"
    width={1920}
    height={1080}
  />
  <!-- Gray overlay -->
  <div class="absolute inset-0 bg-gray-900/90"></div>

  <!-- Content -->
  <div
    class="relative z-10 max-w-screen-xl mx-auto px-6 py-12 md:py-16 text-white text-center"
  >
    <h1 class="text-4xl md:text-6xl font-bold mb-8">
      Uniting & Empowering Filipino<br />Nurses in the Nordics
    </h1>

    <p class="text-lg md:text-xl max-w-4xl mx-auto mb-12">
      FiNAN is a non-profit organization that connects, supports, and advocates
      for Filipino nurses across the Nordic region — providing trusted guidance
      on licensing, cultural integration, and professional growth.
    </p>

    <p class="text-lg text-gray-200 mb-8">
      For more info you can visit our current website <a
        href="https://www.filnan.com"
        target="_blank"
        rel="noopener noreferrer"
        class="underline font-bold hover:text-white transition-colors"
        >www.filnan.com</a
      > or email us at <a
        href="mailto:info@finan.eu.com"
        class="underline font-bold hover:text-white transition-colors"
        >info@finan.eu.com</a
      >
    </p>

    <!-- Action Links -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="https://filnan.com/membership-form"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-white text-gray-900 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors shadow-lg inline-block"
      >
        Become a Member
      </a>
      <a
        href="https://filnan.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-gray-900 transition-colors inline-block"
      >
        About FiNAN
      </a>
    </div>
  </div>
</section>
