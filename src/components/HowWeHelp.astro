---
// HowWeHelp.astro - How We Help section showcasing FiNAN's main service areas
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-screen-xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
        How We Help
      </h2>
      <p class="text-lg text-gray-700 max-w-4xl mx-auto leading-relaxed">
        FiNAN supports Filipino nurses in the Nordics through guidance,
        advocacy, and community building. Explore our main focus areas and find
        resources tailored to your needs.
      </p>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Licensing Guidance Card -->
      <div
        class="bg-white border border-gray-200 rounded-lg p-8 hover:shadow-lg transition-shadow duration-300"
      >
        <!-- Icon -->
        <div class="mb-6">
          <div
            class="w-12 h-12 bg-black rounded-lg flex items-center justify-center"
          >
            <img
              src="/icons/placeholder-icon.svg"
              alt="Licensing Guidance Icon"
              class="w-6 h-6 filter brightness-0 invert"
            />
          </div>
        </div>

        <!-- Content -->
        <h3 class="text-2xl font-bold text-gray-900 mb-4">
          Licensing Guidance
        </h3>
        <p class="text-gray-700 mb-6 leading-relaxed">
          Get step-by-step support for obtaining or renewing your Nordic RN
          license, tailored to each country's specific requirements. FiNAN
          provides clear, reliable information to help you navigate the process
          with confidence.
        </p>

        <!-- Link -->
        <a
          href="#"
          class="inline-flex items-center text-gray-900 font-medium hover:text-gray-700 transition-colors"
        >
          Licensing Guidance
          <svg
            class="w-4 h-4 ml-2"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <!-- Cultural Integration Card -->
      <div
        class="bg-white border border-gray-200 rounded-lg p-8 hover:shadow-lg transition-shadow duration-300"
      >
        <!-- Icon -->
        <div class="mb-6">
          <div
            class="w-12 h-12 bg-black rounded-lg flex items-center justify-center"
          >
            <img
              src="/icons/placeholder-icon.svg"
              alt="Cultural Integration Icon"
              class="w-6 h-6 filter brightness-0 invert"
            />
          </div>
        </div>

        <!-- Content -->
        <h3 class="text-2xl font-bold text-gray-900 mb-4">
          Cultural Integration
        </h3>
        <p class="text-gray-700 mb-6 leading-relaxed">
          Receive dedicated support to help you adapt and thrive in life across
          the Nordic region. FiNAN offers resources for learning the local
          language, understanding cultural norms, and connecting with community
          networks.
        </p>

        <!-- Link -->
        <a
          href="#"
          class="inline-flex items-center text-gray-900 font-medium hover:text-gray-700 transition-colors"
        >
          Cultural Integration
          <svg
            class="w-4 h-4 ml-2"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <!-- Policy Advocacy Card -->
      <div
        class="bg-white border border-gray-200 rounded-lg p-8 hover:shadow-lg transition-shadow duration-300"
      >
        <!-- Icon -->
        <div class="mb-6">
          <div
            class="w-12 h-12 bg-black rounded-lg flex items-center justify-center"
          >
            <img
              src="/icons/placeholder-icon.svg"
              alt="Policy Advocacy Icon"
              class="w-6 h-6 filter brightness-0 invert"
            />
          </div>
        </div>

        <!-- Content -->
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Policy Advocacy</h3>
        <p class="text-gray-700 mb-6 leading-relaxed">
          We actively collaborate with government policymakers, hospitals,
          healthcare institutions, and universities to improve the recognition
          of Filipino nurses' qualifications and enhance their professional
          well-being.
        </p>

        <!-- Link -->
        <a
          href="#"
          class="inline-flex items-center text-gray-900 font-medium hover:text-gray-700 transition-colors"
        >
          Policy Advocacy
          <svg
            class="w-4 h-4 ml-2"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Nordic Chapters Section -->
<section class="py-16 md:py-24 bg-white">
  <div class="max-w-screen-xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
        Our Nordic Chapters
      </h2>
      <p class="text-lg text-gray-700 max-w-4xl mx-auto leading-relaxed">
        FiNAN unites Filipino nurses across the Nordic region through local
        chapters. Select your country to connect with your chapter, access local
        resources, and join community events.
      </p>
    </div>

    <!-- Country Links Grid -->
    <div class="flex flex-wrap justify-center gap-4 mb-8 max-w-3xl mx-auto">
      <!-- Denmark -->
      <a
        href="#"
        class="flex items-center gap-3 px-6 py-3 border-2 border-gray-300 rounded-lg hover:border-gray-900 hover:bg-gray-50 transition-all duration-300 min-w-[140px]"
      >
        <img
          src="/src/assets/images/flags/190-denmark.svg"
          alt="Denmark flag"
          class="w-6 h-6"
        />
        <span class="font-medium text-gray-900">Denmark</span>
      </a>

      <!-- Faroe Islands -->
