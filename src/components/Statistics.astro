---
// Statistics.astro - Statistics section showcasing FiNAN's impact
import { statisticsConfig } from '../data/statisticsConfig';
---

<section class="bg-gray-50 py-16 md:py-24">
  <div class="mx-auto max-w-screen-xl px-6">
    <!-- Header -->
    <div class="mb-16">
      <p class="mb-4 text-sm font-medium text-gray-600">
        {statisticsConfig.section.subtitle}
      </p>

      <div class="grid items-start gap-8 lg:grid-cols-2 lg:gap-16">
        <div>
          <h2
            class="mb-6 text-4xl leading-tight font-bold text-gray-900 md:text-5xl"
            set:html={statisticsConfig.section.title}
          />
        </div>

        <div>
          <p class="mb-8 text-lg leading-relaxed text-gray-600">
            {statisticsConfig.section.description}
          </p>

          <div class="flex flex-col gap-4 sm:flex-row">
            <a
              href={statisticsConfig.section.buttons.primary.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block rounded-lg bg-blue-900 px-6 py-3 text-center font-medium text-white transition-colors hover:bg-blue-800"
            >
              {statisticsConfig.section.buttons.primary.text}
            </a>
            <a
              href={statisticsConfig.section.buttons.secondary.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-6 py-3 text-center font-medium text-gray-900 transition-colors hover:text-gray-700"
            >
              {statisticsConfig.section.buttons.secondary.text}
              <svg
                class="ml-2 h-4 w-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid gap-8 md:grid-cols-3">
      {
        statisticsConfig.cards.map((card) => (
          <div class="rounded-lg border border-gray-200 bg-white p-8">
            <div class="mb-4 text-5xl font-bold text-gray-900 md:text-6xl">
              {card.value}
            </div>
            <h3 class="mb-3 text-xl font-semibold text-gray-900">
              {card.title}
            </h3>
            <p class="leading-relaxed text-gray-600">{card.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
