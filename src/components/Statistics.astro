---
// Statistics.astro - Statistics section showcasing FiNAN's impact
import { statisticsConfig } from '../data/statisticsConfig';
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-screen-xl mx-auto px-6">
    <!-- Header -->
    <div class="mb-16">
      <p class="text-sm text-gray-600 mb-4 font-medium">
        {statisticsConfig.section.subtitle}
      </p>

      <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-start">
        <div>
          <h2
            class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 leading-tight"
            set:html={statisticsConfig.section.title}
          >
          </h2>
        </div>

        <div>
          <p class="text-lg text-gray-600 mb-8 leading-relaxed">
            {statisticsConfig.section.description}
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={statisticsConfig.section.buttons.primary.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-6 py-3 bg-blue-900 text-white font-medium rounded-lg hover:bg-blue-800 transition-colors text-center"
            >
              {statisticsConfig.section.buttons.primary.text}
            </a>
            <a
              href={statisticsConfig.section.buttons.secondary.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-6 py-3 text-gray-900 font-medium hover:text-gray-700 transition-colors text-center"
            >
              {statisticsConfig.section.buttons.secondary.text}
              <svg
                class="ml-2 w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid md:grid-cols-3 gap-8">
      {statisticsConfig.cards.map((card) => (
        <div class="bg-white p-8 border border-gray-200 rounded-lg">
          <div class="text-5xl md:text-6xl font-bold text-gray-900 mb-4">
            {card.value}
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">
            {card.title}
          </h3>
          <p class="text-gray-600 leading-relaxed">
            {card.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
