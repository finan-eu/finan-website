---
import type { FAQCategory } from '../data/pages/faq/faqData';

interface Props {
  categories: readonly FAQCategory[];
}

const { categories } = Astro.props;

// Generate a global counter for unique IDs across all categories
let globalFaqIndex = 0;
---

<div class="mx-auto max-w-4xl px-4 sm:px-6">
  <!-- Hidden heading for screen readers to improve document outline -->
  <h2 id="faq-heading" class="sr-only">List of Frequently Asked Questions</h2>

  <div class="space-y-12">
    {
      categories.map((category) => (
        <div class="category-section">
          {/* Category header */}
          <div class="mb-6">
            <h3 class="text-2xl font-bold text-gray-900 md:text-3xl">
              {category.categoryName}
            </h3>
            {category.categoryDescription && (
              <p class="mt-2 text-base text-gray-600 md:text-lg">
                {category.categoryDescription}
              </p>
            )}
          </div>

          {/* FAQs within the category */}
          <div
            class="space-y-4"
            role="list"
            aria-label={`${category.categoryName} questions`}
          >
            {category.faqs.map((faq) => {
              const currentIndex = ++globalFaqIndex;
              return (
                <div
                  class="group rounded-lg border border-gray-200 bg-white shadow-sm transition-all duration-200 hover:shadow-md"
                  role="listitem"
                >
                  <button
                    type="button"
                    class="faq-toggle flex w-full items-start justify-between gap-4 px-6 py-5 text-left transition-colors hover:bg-gray-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-900 focus-visible:ring-offset-2 aria-expanded:bg-gray-50"
                    aria-expanded="false"
                    aria-controls={`faq-answer-${currentIndex}`}
                    data-faq-index={currentIndex}
                  >
                    <div class="flex-1">
                      <h4
                        id={`faq-question-${currentIndex}`}
                        class="pr-4 text-lg font-semibold text-gray-900 md:text-xl"
                      >
                        {faq.question}
                      </h4>
                    </div>
                    <div class="flex items-center gap-2">
                      {/* Expand/collapse icon */}
                      <svg
                        class="chevron h-6 w-6 flex-shrink-0 text-gray-500 transition-transform duration-200"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M19 9l-7 7-7-7"
                        />
                      </svg>
                    </div>
                  </button>
                  <div
                    id={`faq-answer-${currentIndex}`}
                    class="faq-content overflow-hidden transition-all duration-300 ease-in-out"
                    style="max-height: 0;"
                    aria-labelledby={`faq-question-${currentIndex}`}
                    role="region"
                  >
                    <div class="border-t border-gray-100 px-6 py-5">
                      <p class="text-base text-gray-700 md:text-lg">
                        {faq.answer}
                      </p>
                      {faq.followUpLink && (
                        <p class="mt-3 text-base text-gray-700 md:text-lg">
                          {faq.followUpLink.prefix}
                          <a
                            href={faq.followUpLink.href}
                            class="font-semibold text-blue-900 underline decoration-blue-300 underline-offset-4 transition-colors hover:text-blue-700"
                          >
                            {faq.followUpLink.text}
                          </a>
                        </p>
                      )}
                      {faq.registrationDetails && (
                        <div class="mt-4 space-y-3">
                          <p class="text-sm font-semibold text-gray-900 md:text-base">
                            Registration Details:
                          </p>
                          <dl class="space-y-2 rounded-lg bg-gray-50 p-4">
                            {faq.registrationDetails.map((reg) => (
                              <div class="flex flex-col gap-1 sm:flex-row sm:gap-2">
                                <dt class="min-w-fit text-sm font-medium text-gray-700 md:text-base">
                                  {reg.organization}:
                                </dt>
                                <dd class="text-sm text-gray-600 md:text-base">
                                  {reg.registrationNumber}
                                </dd>
                              </div>
                            ))}
                          </dl>
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))
    }
  </div>
</div>

<script>
  // FAQ Accordion functionality
  function initFAQAccordion() {
    const toggleButtons = document.querySelectorAll('.faq-toggle');

    toggleButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const content = button.nextElementSibling as HTMLElement;
        const chevron = button.querySelector('.chevron');
        const isExpanded = button.getAttribute('aria-expanded') === 'true';

        // Toggle the current FAQ
        if (isExpanded) {
          button.setAttribute('aria-expanded', 'false');
          content.style.maxHeight = '0';
          chevron?.classList.remove('rotate-180');
        } else {
          button.setAttribute('aria-expanded', 'true');
          content.style.maxHeight = content.scrollHeight + 'px';
          chevron?.classList.add('rotate-180');
        }
      });
    });
  }

  // astro:page-load fires on both initial load and after client-side navigation (View Transitions)
  document.addEventListener('astro:page-load', initFAQAccordion);
</script>

<style>
  .faq-content {
    transition:
      max-height 0.3s ease-in-out,
      opacity 0.3s ease-in-out;
  }

  .chevron {
    transition: transform 0.2s ease-in-out;
  }

  /* When collapsed, button should have rounded bottom corners too */
  .faq-toggle[aria-expanded='false'] {
    border-radius: 0.5rem; /* rounded-lg */
  }

  /* When expanded, only top corners should be rounded */
  .faq-toggle[aria-expanded='true'] {
    border-top-left-radius: 0.5rem;
    border-top-right-radius: 0.5rem;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }
</style>
