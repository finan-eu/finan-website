---
import type { FAQ } from '../data/pages/faq/faqData';

interface Props {
  faqs: readonly FAQ[];
}

const { faqs } = Astro.props;
---

<div class="mx-auto max-w-screen-xl px-4 sm:px-6">
  <!-- Hidden heading for screen readers to improve document outline -->
  <h2 id="faq-heading" class="sr-only">
    List of Frequently Asked Questions
  </h2>
  <div class="space-y-4" role="list" aria-label="Frequently asked questions">
    {
      faqs.map((faq, index) => (
        <div
          class="group rounded-lg border border-gray-200 bg-white shadow-sm transition-all duration-200 hover:shadow-md"
          role="listitem"
        >
            <button
              type="button"
              class="faq-toggle flex w-full items-start justify-between gap-4 px-6 py-5 text-left transition-colors hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-900 focus:ring-offset-2"
              aria-expanded="false"
              aria-controls={`faq-answer-${index + 1}`}
              data-faq-index={index}
            >
              <div class="flex-1">
                <h3
                  id={`faq-question-${index + 1}`}
                  class="pr-4 text-lg font-semibold text-gray-900 md:text-xl"
                >
                  <span class="mr-2 text-gray-900">{index + 1}.</span>
                  {faq.question}
                </h3>
              </div>
              <div class="flex items-center gap-2">
                <!-- Expand/collapse icon -->
                <svg
                  class="chevron h-6 w-6 flex-shrink-0 text-gray-500 transition-transform duration-200"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"
                  />
                </svg>
              </div>
            </button>
            <div
              id={`faq-answer-${index + 1}`}
              class="faq-content overflow-hidden transition-all duration-300 ease-in-out"
              style="max-height: 0;"
              aria-labelledby={`faq-question-${index + 1}`}
              role="region"
            >
              <div class="border-t border-gray-100 px-6 py-5">
                <p class="text-base text-gray-700 md:text-lg">{faq.answer}</p>
              </div>
            </div>
          </div>
        ))
    }
  </div>
</div>

<script>
  // FAQ Accordion functionality
  function initFAQAccordion() {
    const toggleButtons = document.querySelectorAll('.faq-toggle');

    toggleButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const content = button.nextElementSibling as HTMLElement;
        const chevron = button.querySelector('.chevron');
        const isExpanded = button.getAttribute('aria-expanded') === 'true';

        // Toggle the current FAQ
        if (isExpanded) {
          button.setAttribute('aria-expanded', 'false');
          content.style.maxHeight = '0';
          chevron?.classList.remove('rotate-180');
        } else {
          button.setAttribute('aria-expanded', 'true');
          content.style.maxHeight = content.scrollHeight + 'px';
          chevron?.classList.add('rotate-180');
        }
      });
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFAQAccordion);
  } else {
    initFAQAccordion();
  }
</script>

<style>
  .faq-content {
    transition:
      max-height 0.3s ease-in-out,
      opacity 0.3s ease-in-out;
  }

  .chevron {
    transition: transform 0.2s ease-in-out;
  }

  /* When collapsed, button should have rounded bottom corners too */
  .faq-toggle[aria-expanded='false'] {
    border-radius: 0.5rem; /* rounded-lg */
  }

  /* When expanded, only top corners should be rounded */
  .faq-toggle[aria-expanded='true'] {
    border-top-left-radius: 0.5rem;
    border-top-right-radius: 0.5rem;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }
</style>
