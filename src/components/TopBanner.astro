---
// TopBanner.astro - Site-wide announcement banner
const flags = [
  { alt: 'Flag of Denmark', src: '/flags/190-denmark.svg' },
  { alt: 'Flag of Sweden', src: '/flags/189-sweden.svg' },
  { alt: 'Flag of Norway', src: '/flags/204-norway.svg' },
  { alt: 'Flag of Finland', src: '/flags/210-finland.svg' },
  { alt: 'Flag of Iceland', src: '/flags/221-iceland.svg' },
  { alt: 'Flag of Greenland', src: '/flags/078-greenland.svg' },
  { alt: 'Flag of the Faroe Islands', src: '/flags/115-faroe islands.svg' },
  { alt: 'Flag of Aland Islands', src: '/flags/156-aland islands.svg' },
];
---

<div class="bg-blue-900 px-4 py-4">
  <div class="mx-auto max-w-3xl text-center text-lg text-white">
    <p>
      We're building a new website to better serve Filipino nurses across the
      Nordic region. Thanks for your patience as we continue updating the site.
    </p>
    <ul
      class="mt-3 flex list-none flex-wrap items-center justify-center gap-2"
      aria-label="Nordic region flags"
    >
      {
        flags.map((flag) => (
          <li>
            <img
              src={flag.src}
              alt={flag.alt}
              class="h-6 w-8"
              loading="lazy"
              width={32}
              height={24}
            />
          </li>
        ))
      }
    </ul>
  </div>
</div>
