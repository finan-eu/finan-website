---
// RegistrationSection.astro - Organization registration information
import { Image } from 'astro:assets';
import finlandPrhImg from '../assets/images/registrations/finland-prh.png';
import denmarkErhvervsstyrelsenImg from '../assets/images/registrations/denmark-erhvervsstyrelsen.png';
import swedenSkatteverketImg from '../assets/images/registrations/sweden-skatteverket.png';
import icelandRikisskattstjoriImg from '../assets/images/registrations/iceland-rikisskattstjori.jpg';
---

<section class="bg-white py-16">
  <div class="max-w-screen-xl mx-auto px-6">
    <!-- Intro text -->
    <div class="text-center mb-12">
      <p class="text-lg text-gray-700 max-w-3xl mx-auto">
        <span class="font-bold"
          >The Filipino Nurses Association in the Nordic Region</span
        > is a registered non-profit organization in the Nordic Region.
      </p>
    </div>

    <!-- Registration Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
      <!-- PRH Card -->
      <div class="text-center">
        <div
          class="bg-gray-50 p-6 rounded-lg mb-4 flex h-52 flex-col items-center gap-4"
        >
          <div class="flex-1 flex items-center justify-center w-full">
            <Image
              src={finlandPrhImg}
              alt="Finnish Patent and Registration Office (PRH)"
              class="w-full max-h-24 object-contain"
              loading="lazy"
              format="webp"
              width={360}
            />
          </div>
          <div class="text-center">
            <p class="text-md font-semibold text-slate-700">
              Patentti- ja rekisterihallitus
            </p>
            <p class="text-sm text-slate-600">Y-tunnus: 3084026-2</p>
          </div>
        </div>
      </div>

      <!-- Danish CVR Card -->
      <div class="text-center">
        <div
          class="bg-gray-50 p-6 rounded-lg mb-4 flex h-52 flex-col items-center gap-4"
        >
          <div class="flex-1 flex items-center justify-center w-full">
            <Image
              src={denmarkErhvervsstyrelsenImg}
              alt="Danish Business Authority (Erhvervsstyrelsen)"
              class="w-full max-h-24 object-contain"
              loading="lazy"
              format="webp"
              width={360}
            />
          </div>
          <div class="text-center">
            <p class="text-md font-semibold text-slate-700">
              Erhvervsstyrelsen
            </p>
            <p class="text-sm text-slate-600">CVR number: 40349367</p>
          </div>
        </div>
      </div>

      <!-- Skatteverket Card -->
      <div class="text-center">
        <div
          class="bg-gray-50 p-6 rounded-lg mb-4 flex h-52 flex-col items-center gap-4"
        >
          <div class="flex-1 flex items-center justify-center w-full">
            <Image
              src={swedenSkatteverketImg}
              alt="Swedish Tax Agency (Skatteverket)"
              class="w-full max-h-24 object-contain"
              loading="lazy"
              format="webp"
              width={360}
            />
          </div>
          <div class="text-center">
            <p class="text-md font-semibold text-slate-700">Skatteverket</p>
            <p class="text-sm text-slate-600">
              Organisation number: 802537-7097
            </p>
          </div>
        </div>
      </div>

      <!-- Iceland RSK Card -->
      <div class="text-center">
        <div
          class="bg-gray-50 p-6 rounded-lg mb-4 flex h-52 flex-col items-center gap-4"
        >
          <div class="flex-1 flex items-center justify-center w-full">
            <Image
              src={icelandRikisskattstjoriImg}
              alt="Directorate of Internal Revenue (Ríkisskattstjóri)"
              class="w-full max-h-24 object-contain"
              loading="lazy"
              format="webp"
              width={360}
            />
          </div>
          <div class="text-center">
            <p class="text-md font-semibold text-slate-700">Ríkisskattstjóri</p>
            <p class="text-sm text-slate-600">
              Registration number: 5208190450
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
