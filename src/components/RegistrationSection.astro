---
// RegistrationSection.astro - Organization registration information
import { Image } from 'astro:assets';
import { registrationSectionConfig } from '../data/registrationSectionConfig';
---

<section class="bg-white py-16">
  <div class="max-w-screen-xl mx-auto px-6">
    <!-- Intro text -->
    <div class="text-center mb-12">
      <p class="text-lg text-gray-700 max-w-3xl mx-auto">
        <span class="font-bold">{registrationSectionConfig.title.highlight}</span>
        {registrationSectionConfig.title.normal}
      </p>
    </div>

    <!-- Registration Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
      {registrationSectionConfig.entities.map((entity) => (
        <div class="text-center">
          <div class="bg-gray-50 p-6 rounded-lg mb-4 flex h-52 flex-col items-center gap-4">
            <div class="flex-1 flex items-center justify-center w-full">
              <Image
                src={entity.image.src}
                alt={entity.image.alt}
                class="w-full max-h-24 object-contain"
                loading={entity.image.loading}
                format={entity.image.format}
                width={entity.image.width}
              />
            </div>
            <div class="text-center">
              <p class="text-md font-semibold text-slate-700">
                {entity.organizationNameLocal}
              </p>
              <p class="text-sm text-slate-600">
                {entity.registrationLabel}: {entity.registrationNumber}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
