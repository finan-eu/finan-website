---
// RegistrationSection.astro - Organization registration information
import { Image } from 'astro:assets';
import patenttiImg from '../assets/patentti.jpg';
import danishNgoImg from '../assets/danish-ngo.png';
import skatteverketImg from '../assets/skv-fb-liggande.png';
import icelandNgoImg from '../assets/iceland ngo.jpg';
---

<section class="bg-white py-16">
  <div class="max-w-screen-xl mx-auto px-6">
    <!-- Intro text -->
    <div class="text-center mb-12">
      <p class="text-lg text-gray-700 max-w-3xl mx-auto">
        <span class="font-bold"
          >The Filipino Nurses Association in the Nordic Region</span
        > is a registered non-profit organization in the Nordic Region.
      </p>
    </div>

    <!-- Registration Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
      <!-- PRH Card -->
      <div class="text-center">
        <div class="bg-gray-50 p-6 rounded-lg mb-4">
          <Image
            src={patenttiImg}
            alt="PRH - Patent- och registerstyrelsen"
            class="h-20 mx-auto object-contain"
            loading="lazy"
            format="webp"
            width={80}
            height={80}
          />
        </div>
        <div class="bg-slate-600 text-white px-4 py-2 rounded">
          <span class="text-sm font-medium">Y-tunnus: 3084026-2</span>
        </div>
      </div>

      <!-- Danish CVR Card -->
      <div class="text-center">
        <div class="bg-gray-50 p-6 rounded-lg mb-4">
          <Image
            src={danishNgoImg}
            alt="Erhvervsstyrelsen"
            class="h-20 mx-auto object-contain"
            loading="lazy"
            format="webp"
            width={80}
            height={80}
          />
        </div>
        <div class="bg-slate-600 text-white px-4 py-2 rounded">
          <span class="text-sm font-medium">CVR number: 40349367</span>
        </div>
      </div>

      <!-- Skatteverket Card -->
      <div class="text-center">
        <div class="bg-gray-50 p-6 rounded-lg mb-4">
          <Image
            src={skatteverketImg}
            alt="Skatteverket"
            class="h-20 mx-auto object-contain"
            loading="lazy"
            format="webp"
            width={80}
            height={80}
          />
        </div>
        <div class="bg-slate-600 text-white px-4 py-2 rounded">
          <span class="text-sm font-medium"
            >Oganisationsnummer: 802537-7097</span
          >
        </div>
      </div>

      <!-- Iceland RSK Card -->
      <div class="text-center">
        <div class="bg-gray-50 p-6 rounded-lg mb-4">
          <Image
            src={icelandNgoImg}
            alt="Ríkisskattstjóri"
            class="h-20 mx-auto object-contain"
            loading="lazy"
            format="webp"
            width={80}
            height={80}
          />
        </div>
        <div class="bg-slate-600 text-white px-4 py-2 rounded">
          <span class="text-sm font-medium"
            >Registration number: 5208190450</span
          >
        </div>
      </div>
    </div>
  </div>
</section>
