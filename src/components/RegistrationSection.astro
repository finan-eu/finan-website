---
// RegistrationSection.astro - Organization registration information
import { Image } from 'astro:assets';
import { registrationSectionConfig } from '../data/registrationSectionConfig';
---

<section class="bg-white py-16">
  <div class="mx-auto max-w-screen-xl px-6">
    <!-- Intro text -->
    <div class="mb-12 text-center">
      <p class="mx-auto max-w-3xl text-lg text-gray-700">
        <span class="font-bold"
          >{registrationSectionConfig.title.highlight}</span
        >
        {registrationSectionConfig.title.normal}
      </p>
    </div>

    <!-- Registration Cards Grid -->
    <div class="mb-12 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
      {
        registrationSectionConfig.entities.map((entity) => (
          <div class="text-center">
            <div class="mb-4 flex h-52 flex-col items-center gap-4 rounded-lg bg-gray-50 p-6">
              <div class="flex w-full flex-1 items-center justify-center">
                <Image
                  src={entity.image.src}
                  alt={entity.image.alt}
                  class={`w-full object-contain ${entity.id === 'iceland-rikisskattstjori' ? 'max-h-16' : 'max-h-24'}`}
                  loading={entity.image.loading}
                  format={entity.image.format}
                  width={entity.image.width}
                />
              </div>
              <div class="text-center">
                <p class="text-md font-semibold text-slate-700">
                  {entity.organizationNameLocal}
                </p>
                <p class="text-sm text-slate-600">
                  {entity.registrationLabel}: {entity.registrationNumber}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
