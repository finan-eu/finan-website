---
// NordicRepresentation.astro - Nordic Representation section showcasing FiNAN's regional presence
---

<!-- Nordic Representation Section -->
<section class="bg-white py-16 md:py-24">
  <div class="mx-auto max-w-screen-xl px-6">
    <!-- Header -->
    <div class="mb-16 text-center">
      <h2 class="mb-6 text-3xl font-bold text-gray-900 md:text-4xl">
        Our Nordic Representation
      </h2>
      <p class="mx-auto max-w-4xl text-lg leading-relaxed text-gray-700">
        FiNAN unites Filipino nurses across the Nordic region through local
        representation. Select your country to connect with your representation,
        access local resources, and join community events.
      </p>
    </div>

    <!-- Country Links Grid -->
    <div class="mx-auto mb-8 flex max-w-3xl flex-wrap justify-center gap-4">
      <!-- Denmark -->
      <a
        href="/representation/denmark"
        class="flex min-w-[140px] items-center gap-3 rounded-lg border-2 border-gray-300 px-6 py-3 transition-all duration-300 hover:border-blue-900 hover:shadow-lg"
      >
        <img src="/flags/190-denmark.svg" alt="Denmark flag" class="h-6 w-6" />
        <span class="font-medium text-gray-900">Denmark</span>
      </a>

      <!-- Faroe Islands -->
      <a
        href="/representation/faroe-islands"
        class="flex min-w-[140px] items-center gap-3 rounded-lg border-2 border-gray-300 px-6 py-3 transition-all duration-300 hover:border-blue-900 hover:shadow-lg"
      >
        <img
          src="/flags/115-faroe islands.svg"
          alt="Faroe Islands flag"
          class="h-6 w-6"
        />
        <span class="font-medium text-gray-900">Faroe Islands</span>
      </a>

      <!-- Finland -->
      <a
        href="/representation/finland"
        class="flex min-w-[140px] items-center gap-3 rounded-lg border-2 border-gray-300 px-6 py-3 transition-all duration-300 hover:border-blue-900 hover:shadow-lg"
      >
        <img src="/flags/210-finland.svg" alt="Finland flag" class="h-6 w-6" />
        <span class="font-medium text-gray-900">Finland</span>
      </a>

      <!-- Greenland -->
      <a
        href="/representation/greenland"
        class="flex min-w-[140px] items-center gap-3 rounded-lg border-2 border-gray-300 px-6 py-3 transition-all duration-300 hover:border-blue-900 hover:shadow-lg"
      >
        <img
          src="/flags/078-greenland.svg"
          alt="Greenland flag"
          class="h-6 w-6"
        />
        <span class="font-medium text-gray-900">Greenland</span>
      </a>

      <!-- Iceland -->
      <a
        href="/representation/iceland"
        class="flex min-w-[140px] items-center gap-3 rounded-lg border-2 border-gray-300 px-6 py-3 transition-all duration-300 hover:border-blue-900 hover:shadow-lg"
      >
        <img src="/flags/221-iceland.svg" alt="Iceland flag" class="h-6 w-6" />
        <span class="font-medium text-gray-900">Iceland</span>
      </a>

      <!-- Norway -->
      <a
        href="/representation/norway"
        class="flex min-w-[140px] items-center gap-3 rounded-lg border-2 border-gray-300 px-6 py-3 transition-all duration-300 hover:border-blue-900 hover:shadow-lg"
      >
        <img src="/flags/204-norway.svg" alt="Norway flag" class="h-6 w-6" />
        <span class="font-medium text-gray-900">Norway</span>
      </a>

      <!-- Sweden -->
      <a
        href="/representation/sweden"
        class="flex min-w-[140px] items-center gap-3 rounded-lg border-2 border-gray-300 px-6 py-3 transition-all duration-300 hover:border-blue-900 hover:shadow-lg"
      >
        <img src="/flags/189-sweden.svg" alt="Sweden flag" class="h-6 w-6" />
        <span class="font-medium text-gray-900">Sweden</span>
      </a>
    </div>
  </div>
</section>
