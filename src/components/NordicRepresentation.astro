---
// NordicRepresentation.astro - Nordic Representation section showcasing FiNAN's regional presence
---

<!-- Nordic Representation Section -->
<section class="bg-white py-16 md:py-24">
  <div class="mx-auto max-w-screen-xl px-6">
    <!-- Header -->
    <div class="mb-16 text-center">
      <h2 class="mb-6 text-3xl font-bold text-gray-900 md:text-5xl">
        Nordic Representation
      </h2>
      <p class="mx-auto max-w-4xl text-lg leading-relaxed text-gray-700">
        FiNAN unites Filipino nurses across the Nordic region through local
        representation. Select your country to connect with your representation,
        access local resources, and join community events.
      </p>
    </div>

    <!-- Country Links Grid -->
    <div class="mx-auto mb-8 flex flex-wrap justify-center gap-4">
      <!-- Kingdom of Denmark -->
      <a
        href="/representation/kingdom-denmark"
        class="flex min-w-[140px] items-center gap-3 rounded-full border-2 border-gray-300 px-6 py-3 transition-all duration-300 hover:border-blue-900 hover:shadow-lg"
      >
        <img
          src="/assets/flags/flag_denmark.svg"
          alt="Denmark flag"
          class="h-6 w-6"
        />
        <span class="font-medium text-gray-900">Kingdom of Denmark</span>
      </a>

      <!-- Faroe Islands -->
