---
import { Image } from 'astro:assets';
import {
  finlandCommittee,
  swedenCommittee,
  norwayCommittee,
  icelandCommittee,
  greenlandCommittee,
  faroeIslandsCommittee,
} from '../data/representation/working-committee';
---

<section class="bg-white py-16">
  <div class="mx-auto max-w-4xl px-6">
    <header class="max-w-4xl">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 md:text-4xl">
        Regional Representatives
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-gray-600">
        Official regional representatives of the Filipino Nurses Association in
        the Nordic Region
      </p>
    </header>

    <!-- Finland -->
    <div class="mt-12">
      <h3
        class="mb-8 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl"
      >
        {finlandCommittee.heading}
      </h3>
      <div class="flex flex-wrap gap-10">
        {
          finlandCommittee.members.map((member) => (
            <article class="flex max-w-sm min-w-xs flex-1 items-start gap-6">
              <div class="flex-shrink-0">
                <div class="relative h-24 w-24 overflow-hidden rounded-full bg-gray-200">
                  {member.imageSrc ? (
                    typeof member.imageSrc === 'string' ? (
                      <img
                        src={member.imageSrc}
                        alt={member.imageAlt}
                        class="h-full w-full object-cover"
                        loading="lazy"
                      />
                    ) : (
                      <Image
                        src={member.imageSrc}
                        alt={member.imageAlt}
                        class="h-full w-full object-cover"
                        loading="lazy"
                        width={96}
                        height={96}
                      />
                    )
                  ) : (
                    <img
                      src="/images/image_thumbnail.svg"
                      alt={member.imageAlt}
                      class="h-full w-full object-cover"
                      loading="lazy"
                    />
                  )}
                </div>
              </div>

              <div class="min-w-0 flex-1">
                <h4 class="mb-2 text-xl font-bold text-gray-900">
                  {member.name}
                </h4>
                <p class="mb-3 text-lg text-gray-900">{member.role}</p>
                <p class="text-sm leading-relaxed text-gray-700">
                  {member.bio}
                </p>

                {member.linkedinUrl && (
                  <div class="mt-4">
                    <a
                      href={member.linkedinUrl}
                      aria-label={`${member.name}'s LinkedIn profile`}
                      class="inline-flex text-gray-500 transition-colors duration-200 hover:text-gray-900 focus:outline-none focus-visible:text-gray-900"
                    >
                      <span class="sr-only">{member.name} on LinkedIn</span>
                      <img
                        src="/icons/socmed/linkedin.svg"
                        alt=""
                        class="h-7 w-7"
                        aria-hidden="true"
                        loading="lazy"
                      />
                    </a>
                  </div>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <!-- Sweden -->
    <div class="mt-12">
      <h3
        class="mb-8 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl"
      >
        {swedenCommittee.heading}
      </h3>
      <div class="flex flex-wrap gap-10">
        {
          swedenCommittee.members.map((member) => (
            <article class="flex max-w-sm min-w-xs flex-1 items-start gap-6">
              <div class="flex-shrink-0">
                <div class="relative h-24 w-24 overflow-hidden rounded-full bg-gray-200">
                  {member.imageSrc ? (
                    typeof member.imageSrc === 'string' ? (
                      <img
                        src={member.imageSrc}
                        alt={member.imageAlt}
                        class="h-full w-full object-cover"
                        loading="lazy"
                      />
                    ) : (
                      <Image
                        src={member.imageSrc}
                        alt={member.imageAlt}
                        class="h-full w-full object-cover"
                        loading="lazy"
                        width={96}
                        height={96}
                      />
                    )
                  ) : (
                    <img
                      src="/images/image_thumbnail.svg"
                      alt={member.imageAlt}
                      class="h-full w-full object-cover"
                      loading="lazy"
                    />
                  )}
                </div>
              </div>

              <div class="min-w-0 flex-1">
                <h4 class="mb-2 text-xl font-bold text-gray-900">
                  {member.name}
                </h4>
                <p class="mb-3 text-lg text-gray-900">{member.role}</p>
                <p class="text-sm leading-relaxed text-gray-700">
                  {member.bio}
                </p>

                {member.linkedinUrl && (
                  <div class="mt-4">
                    <a
                      href={member.linkedinUrl}
                      aria-label={`${member.name}'s LinkedIn profile`}
                      class="inline-flex text-gray-500 transition-colors duration-200 hover:text-gray-900 focus:outline-none focus-visible:text-gray-900"
                    >
                      <span class="sr-only">{member.name} on LinkedIn</span>
                      <img
                        src="/icons/socmed/linkedin.svg"
                        alt=""
                        class="h-7 w-7"
                        aria-hidden="true"
                        loading="lazy"
                      />
                    </a>
                  </div>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <!-- Norway & Iceland -->
    <div class="mt-12">
      <h3
        class="mb-8 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl"
      >
        Norway & Iceland
      </h3>
      <div class="flex flex-wrap gap-10">
        {
          [...norwayCommittee.members, ...icelandCommittee.members].map(
            (member) => (
              <article class="flex max-w-sm min-w-xs flex-1 items-start gap-6">
                <div class="flex-shrink-0">
                  <div class="relative h-24 w-24 overflow-hidden rounded-full bg-gray-200">
                    {member.imageSrc ? (
                      typeof member.imageSrc === 'string' ? (
                        <img
                          src={member.imageSrc}
                          alt={member.imageAlt}
                          class="h-full w-full object-cover"
                          loading="lazy"
                        />
                      ) : (
                        <Image
                          src={member.imageSrc}
                          alt={member.imageAlt}
                          class="h-full w-full object-cover"
                          loading="lazy"
                          width={96}
                          height={96}
                        />
                      )
                    ) : (
                      <img
                        src="/images/image_thumbnail.svg"
                        alt={member.imageAlt}
                        class="h-full w-full object-cover"
                        loading="lazy"
                      />
                    )}
                  </div>
                </div>

                <div class="min-w-0 flex-1">
                  <h4 class="mb-2 text-xl font-bold text-gray-900">
                    {member.name}
                  </h4>
                  <p class="mb-3 text-lg text-gray-900">{member.role}</p>
                  <p class="text-sm leading-relaxed text-gray-700">
                    {member.bio}
                  </p>

                  {member.linkedinUrl && (
                    <div class="mt-4">
                      <a
                        href={member.linkedinUrl}
                        aria-label={`${member.name}'s LinkedIn profile`}
                        class="inline-flex text-gray-500 transition-colors duration-200 hover:text-gray-900 focus:outline-none focus-visible:text-gray-900"
                      >
                        <span class="sr-only">{member.name} on LinkedIn</span>
                        <img
                          src="/icons/socmed/linkedin.svg"
                          alt=""
                          class="h-7 w-7"
                          aria-hidden="true"
                          loading="lazy"
                        />
                      </a>
                    </div>
                  )}
                </div>
              </article>
            )
          )
        }
      </div>
    </div>

    <!-- Greenland & Faroe Islands -->
    <div class="mt-12">
      <h3
        class="mb-8 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl"
      >
        Greenland & Faroe Islands
      </h3>
      <div class="flex flex-wrap gap-10">
        {
          [...greenlandCommittee.members, ...faroeIslandsCommittee.members].map(
            (member) => (
              <article class="flex max-w-sm min-w-xs flex-1 items-start gap-6">
                <div class="flex-shrink-0">
                  <div class="relative h-24 w-24 overflow-hidden rounded-full bg-gray-200">
                    {member.imageSrc ? (
                      typeof member.imageSrc === 'string' ? (
                        <img
                          src={member.imageSrc}
                          alt={member.imageAlt}
                          class="h-full w-full object-cover"
                          loading="lazy"
                        />
                      ) : (
                        <Image
                          src={member.imageSrc}
                          alt={member.imageAlt}
                          class="h-full w-full object-cover"
                          loading="lazy"
                          width={96}
                          height={96}
                        />
                      )
                    ) : (
                      <img
                        src="/images/image_thumbnail.svg"
                        alt={member.imageAlt}
                        class="h-full w-full object-cover"
                        loading="lazy"
                      />
                    )}
                  </div>
                </div>

                <div class="min-w-0 flex-1">
                  <h4 class="mb-2 text-xl font-bold text-gray-900">
                    {member.name}
                  </h4>
                  <p class="mb-3 text-lg text-gray-900">{member.role}</p>
                  <p class="text-sm leading-relaxed text-gray-700">
                    {member.bio}
                  </p>

                  {member.linkedinUrl && (
                    <div class="mt-4">
                      <a
                        href={member.linkedinUrl}
                        aria-label={`${member.name}'s LinkedIn profile`}
                        class="inline-flex text-gray-500 transition-colors duration-200 hover:text-gray-900 focus:outline-none focus-visible:text-gray-900"
                      >
                        <span class="sr-only">{member.name} on LinkedIn</span>
                        <img
                          src="/icons/socmed/linkedin.svg"
                          alt=""
                          class="h-7 w-7"
                          aria-hidden="true"
                          loading="lazy"
                        />
                      </a>
                    </div>
                  )}
                </div>
              </article>
            )
          )
        }
      </div>
    </div>
  </div>
</section>
